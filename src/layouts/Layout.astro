---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  <script is:inline>
    const t = localStorage.getItem('theme') || 'light';
    if (t === 'dark') document.documentElement.classList.add('dark');
  </script>
</head>
<body class="bg-white dark:bg-[#131315] text-slate-900 dark:text-[#e5e1e4] font-body text-base leading-relaxed transition-colors duration-300">
  <header class="sticky top-0 w-full z-50 bg-white/80 dark:bg-[#131315]/80 backdrop-blur-xl border-b border-slate-100 dark:border-[#353437]">
    <div class="flex items-center justify-between max-w-screen-2xl mx-auto px-4 md:px-12 h-14 md:h-16">
      <!-- Logo -->
      <a href={base} class="shrink-0">
        <img src={`${base}images/logo.png`} alt="SELFISH AAA" class="h-7 md:h-8 object-contain" />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center space-x-6 lg:space-x-8">
        <a class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors font-medium text-xs lg:text-sm whitespace-nowrap tracking-tight uppercase" href={`${base}team/`}>팀소개</a>
        <a class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors font-medium text-xs lg:text-sm whitespace-nowrap tracking-tight uppercase" href={`${base}insights/`}>인사이트</a>
        <a class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors font-medium text-xs lg:text-sm whitespace-nowrap tracking-tight uppercase" href={`${base}gallery/`}>갤러리</a>
        <a class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors font-medium text-xs lg:text-sm whitespace-nowrap tracking-tight uppercase" href={`${base}tools/`}>도구 모음</a>
        <a class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors font-medium text-xs lg:text-sm whitespace-nowrap tracking-tight uppercase" href={`${base}analysis/`}>AI 분석</a>
        <a class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors font-medium text-xs lg:text-sm whitespace-nowrap tracking-tight uppercase" href={`${base}archive/`}>아카이브</a>
      </nav>

      <!-- Right: Theme toggle + Hamburger -->
      <div class="flex items-center gap-2">
        <button id="theme-toggle" class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors p-1">
          <span class="material-symbols-outlined text-xl" id="theme-icon">dark_mode</span>
        </button>
        <button id="menu-toggle" class="md:hidden text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors p-1">
          <span class="material-symbols-outlined text-xl" id="menu-icon">menu</span>
        </button>
      </div>
    </div>

    <!-- Mobile Nav -->
    <nav id="mobile-nav" class="hidden md:hidden border-t border-slate-100 dark:border-[#353437] bg-white/95 dark:bg-[#131315]/95 backdrop-blur-xl">
      <div class="flex flex-col px-6 py-4 space-y-3">
        <a class="text-gray-600 dark:text-gray-300 hover:text-black dark:hover:text-white transition-colors font-medium text-sm py-1" href={`${base}team/`}>팀소개</a>
        <a class="text-gray-600 dark:text-gray-300 hover:text-black dark:hover:text-white transition-colors font-medium text-sm py-1" href={`${base}insights/`}>인사이트</a>
        <a class="text-gray-600 dark:text-gray-300 hover:text-black dark:hover:text-white transition-colors font-medium text-sm py-1" href={`${base}gallery/`}>갤러리</a>
        <a class="text-gray-600 dark:text-gray-300 hover:text-black dark:hover:text-white transition-colors font-medium text-sm py-1" href={`${base}tools/`}>도구 모음</a>
        <a class="text-gray-600 dark:text-gray-300 hover:text-black dark:hover:text-white transition-colors font-medium text-sm py-1" href={`${base}analysis/`}>AI 분석</a>
        <a class="text-gray-600 dark:text-gray-300 hover:text-black dark:hover:text-white transition-colors font-medium text-sm py-1" href={`${base}archive/`}>아카이브</a>
      </div>
    </nav>
  </header>

  <main class="w-full">
    <slot />
  </main>

  <footer class="bg-slate-50 dark:bg-[#0e0e10] border-t border-slate-100 dark:border-[#353437] w-full py-12 md:py-20">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 mb-12 md:mb-16">
        <div class="md:col-span-5">
          <img src={`${base}images/logo.png`} alt="SELFISH AAA" class="h-10 object-contain mb-4" />
          <p class="text-slate-500 dark:text-gray-400 text-sm md:text-base leading-relaxed max-w-sm">
            이기적으로 만들고, 이기적으로 공유한다.
          </p>
        </div>
        <div class="md:col-span-3 md:col-start-7">
          <span class="text-black dark:text-white font-bold text-xs uppercase tracking-widest font-headline block mb-4">Navigate</span>
          <div class="flex flex-col gap-3">
            <a class="text-slate-500 dark:text-gray-400 hover:text-black dark:hover:text-[#FBE830] transition-all text-sm" href={`${base}team/`}>팀소개</a>
            <a class="text-slate-500 dark:text-gray-400 hover:text-black dark:hover:text-[#FBE830] transition-all text-sm" href={`${base}insights/`}>인사이트</a>
            <a class="text-slate-500 dark:text-gray-400 hover:text-black dark:hover:text-[#FBE830] transition-all text-sm" href={`${base}gallery/`}>갤러리</a>
          </div>
        </div>
        <div class="md:col-span-2">
          <span class="text-black dark:text-white font-bold text-xs uppercase tracking-widest font-headline block mb-4">Resources</span>
          <div class="flex flex-col gap-3">
            <a class="text-slate-500 dark:text-gray-400 hover:text-black dark:hover:text-[#FBE830] transition-all text-sm" href={`${base}tools/`}>도구 모음</a>
            <a class="text-slate-500 dark:text-gray-400 hover:text-black dark:hover:text-[#FBE830] transition-all text-sm" href={`${base}analysis/`}>AI 분석</a>
            <a class="text-slate-500 dark:text-gray-400 hover:text-black dark:hover:text-[#FBE830] transition-all text-sm" href="https://github.com/selfishclub-all/aaa" target="_blank">GitHub</a>
          </div>
        </div>
      </div>
      <div class="pt-8 border-t border-slate-200 dark:border-[#353437] flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-slate-400 dark:text-gray-500 text-xs tracking-widest uppercase">
          &copy; 2026 SELFISH CLUB &times; AAA TEAM
        </p>
        <p class="text-slate-400 dark:text-gray-500 text-xs">
          Seoul, Republic of Korea
        </p>
      </div>
    </div>
  </footer>

  <script is:inline>
    (function() {
      const theme = localStorage.getItem('theme') || 'light';
      const icon = document.getElementById('theme-icon');
      if (icon) icon.textContent = theme === 'dark' ? 'light_mode' : 'dark_mode';

      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        if (icon) icon.textContent = isDark ? 'light_mode' : 'dark_mode';
      });

      // Hamburger menu
      const menuToggle = document.getElementById('menu-toggle');
      const menuIcon = document.getElementById('menu-icon');
      const mobileNav = document.getElementById('mobile-nav');
      menuToggle?.addEventListener('click', () => {
        const isOpen = !mobileNav.classList.contains('hidden');
        mobileNav.classList.toggle('hidden');
        menuIcon.textContent = isOpen ? 'menu' : 'close';
      });

      // Close mobile nav on link click
      mobileNav?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileNav.classList.add('hidden');
          menuIcon.textContent = 'menu';
        });
      });
    })();
  </script>
</body>
</html>
