---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';
import { marked } from 'marked';
const base = import.meta.env.BASE_URL;

const memberEntries = await getCollection('members');
const members = memberEntries.map(m => m.data);

// 멤버별 주차 미션 데이터 빌드
const missionsDir = path.resolve('src/content/missions');
const allMissionFiles = fs.existsSync(missionsDir) ? fs.readdirSync(missionsDir) : [];

interface WeekSummary {
  week: number;
  title: string;
  summary: string;
}

function getMemberWeeks(name: string): WeekSummary[] {
  const weeks: WeekSummary[] = [];
  for (let w = 2; w <= 9; w++) {
    const filename = `Week_0${w}_${name}.md`;
    if (!allMissionFiles.includes(filename)) continue;
    const filepath = path.join(missionsDir, filename);
    try {
      const content = fs.readFileSync(filepath, 'utf8');
      if (content.length < 50) continue;
      const body = content.replace(/^---[\s\S]*?---\n?/, '').trim();
      if (!body) continue;
      // 첫 번째 제목(### or ##)과 그 아래 내용에서 요약 추출
      const titleMatch = body.match(/^#+\s+(.+)/m);
      const title = titleMatch ? titleMatch[1].replace(/[*#]/g, '').trim() : '';
      // 첫 200자에서 요약 추출
      const plainText = body
        .replace(/^#+\s+.*/gm, '')
        .replace(/!\[.*?\]\(.*?\)/g, '')
        .replace(/<video[^>]*>.*?<\/video>/g, '')
        .replace(/\[([^\]]*)\]\([^)]*\)/g, '$1')
        .replace(/[*_`#>-]/g, '')
        .trim();
      const summary = plainText.substring(0, 150).replace(/\n+/g, ' ').trim();
      if (summary.length > 10) {
        weeks.push({ week: w, title: title || `Week ${w}`, summary });
      }
    } catch {}
  }
  return weeks;
}

// 멤버별 관심 키워드 추출 (인사이트 컬렉션에서)
const insights = await getCollection('insights');
function getMemberKeywords(name: string): string[] {
  const memberInsights = insights.filter(i => i.data.member === name);
  const kwSet = new Set<string>();
  memberInsights.forEach(i => {
    const kws = i.data.keywords || [];
    (Array.isArray(kws) ? kws : [kws]).forEach((k: string) => kwSet.add(k));
  });
  return [...kwSet].slice(0, 6);
}

// 멤버별 데이터 빌드
const memberData = members.map(m => ({
  ...m,
  weeks: getMemberWeeks(m.name),
  keywords: getMemberKeywords(m.name),
}));
---
<Layout title="팀소개 - AAA 아카이브">
  <!-- Hero Banner -->
  <section class="pt-20 md:pt-24" style="background: linear-gradient(135deg, rgba(251,232,48,0.08) 0%, rgba(251,232,48,0.15) 40%, rgba(200,240,200,0.1) 100%);">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 pt-8 md:pt-10 pb-8 md:pb-10">
      <h1 class="font-headline text-2xl md:text-3xl font-extrabold tracking-tight text-black dark:text-white mb-2">팀 소개</h1>
      <p class="text-sm md:text-base text-slate-600 dark:text-gray-400 mb-4">매주 AI로 <strong class="text-black dark:text-white">실전 프로젝트</strong>를 만드는 빌더들의 기록.</p>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1 text-xs font-medium border border-slate-200 dark:border-[#353437] rounded-full text-slate-600 dark:text-gray-400 bg-white/60 dark:bg-[#1b1b1d]/60">#빌더</span>
        <span class="px-3 py-1 text-xs font-medium border border-slate-200 dark:border-[#353437] rounded-full text-slate-600 dark:text-gray-400 bg-white/60 dark:bg-[#1b1b1d]/60">#AI</span>
        <span class="px-3 py-1 text-xs font-medium border border-slate-200 dark:border-[#353437] rounded-full text-slate-600 dark:text-gray-400 bg-white/60 dark:bg-[#1b1b1d]/60">#이기적 공유</span>
      </div>
    </div>
  </section>

  <!-- Team Grid -->
  <section class="px-6 md:px-12 pt-8 pb-16 max-w-screen-2xl mx-auto">
    <div class="mb-4 flex items-center gap-4">
      <span class="text-xs font-bold uppercase tracking-widest text-slate-400 dark:text-gray-500">{members.length}명의 빌더</span>
      <div class="h-px flex-grow bg-slate-200 dark:bg-[#353437]"></div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-3 md:gap-4">
      {memberData.map((member) => (
        <div
          class="bg-white dark:bg-[#1b1b1d] group transition-all hover:shadow-lg p-4 border border-slate-100 dark:border-[#353437] hover:border-[#FBE830]/50 rounded-lg cursor-pointer member-card"
          data-name={member.name}
          data-role={member.role}
          data-desc={member.desc || ''}
          data-avatar={member.avatar || ''}
          data-linkedin={member.linkedin || ''}
          data-keywords={JSON.stringify(member.keywords)}
          data-weeks={JSON.stringify(member.weeks)}
        >
          <div class="flex items-center gap-3 mb-3">
            {member.avatar ? (
              <img src={member.avatar} alt={member.name} class="w-10 h-10 shrink-0 rounded-full object-cover border border-slate-200 dark:border-[#353437]" />
            ) : (
              <div class="w-10 h-10 shrink-0 bg-slate-100 dark:bg-[#252527] rounded-full flex items-center justify-center">
                <span class="text-sm font-bold text-slate-400 dark:text-gray-500">{(member.name || '?').charAt(0)}</span>
              </div>
            )}
            <div>
              <h3 class="font-headline text-base font-bold tracking-tight text-black dark:text-white">{member.name}</h3>
              <p class="text-slate-400 dark:text-gray-500 text-[9px] font-semibold uppercase tracking-widest">{member.role}</p>
            </div>
          </div>
          {member.desc && (
            <p class="text-xs leading-relaxed text-slate-500 dark:text-gray-400 line-clamp-3">{member.desc}</p>
          )}
          {member.keywords.length > 0 && (
            <div class="flex flex-wrap gap-1 mt-3">
              {member.keywords.slice(0, 3).map((kw: string) => (
                <span class="text-[9px] px-1.5 py-0.5 rounded bg-[#FBE830]/10 text-[#b8960a] dark:text-[#FBE830] font-medium">{kw}</span>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>

  <!-- Member Modal -->
  <div id="member-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeMemberModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-lg max-h-[85vh] overflow-y-auto bg-white dark:bg-[#1b1b1d] rounded-2xl shadow-2xl p-6 md:p-8">
      <button onclick="closeMemberModal()" class="absolute top-4 right-4 text-slate-400 hover:text-black dark:hover:text-white transition-colors">
        <span class="material-symbols-outlined">close</span>
      </button>

      <!-- Header -->
      <div class="flex items-center gap-4 mb-6">
        <div id="mm-avatar-wrap"></div>
        <div>
          <h2 id="mm-name" class="font-headline text-xl font-bold text-black dark:text-white"></h2>
          <p id="mm-role" class="text-[10px] font-semibold uppercase tracking-widest text-slate-400 dark:text-gray-500"></p>
        </div>
      </div>

      <!-- Desc -->
      <p id="mm-desc" class="text-sm text-slate-600 dark:text-gray-400 leading-relaxed mb-5"></p>

      <!-- LinkedIn -->
      <div id="mm-linkedin-wrap" class="hidden mb-5">
        <a id="mm-linkedin" href="" target="_blank" class="inline-flex items-center gap-1.5 text-[11px] font-bold text-[#0a66c2] dark:text-[#5bb5f0] hover:underline px-2.5 py-1.5 rounded-md bg-[#0a66c2]/5 dark:bg-[#5bb5f0]/10">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
      </div>

      <!-- Keywords -->
      <div id="mm-keywords-wrap" class="hidden mb-6">
        <h3 class="text-xs font-bold text-slate-400 dark:text-gray-500 uppercase tracking-widest mb-2">관심 키워드</h3>
        <div id="mm-keywords" class="flex flex-wrap gap-1.5"></div>
      </div>

      <!-- Weekly Insights -->
      <div id="mm-weeks-wrap" class="hidden">
        <h3 class="text-xs font-bold text-slate-400 dark:text-gray-500 uppercase tracking-widest mb-3">주차별 인사이트</h3>
        <div id="mm-weeks" class="space-y-3"></div>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <section class="py-24 md:py-32 bg-slate-50 dark:bg-[#0e0e10] relative overflow-hidden border-y border-slate-100 dark:border-[#353437]">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 flex flex-col md:flex-row justify-between items-center gap-8">
      <div>
        <h2 class="font-headline text-2xl md:text-3xl lg:text-4xl font-extralight tracking-tighter text-black dark:text-white leading-tight">
          이기적으로 만들고,<br/>
          <span class="font-extrabold border-b-8 border-[#FBE830]">이기적으로 공유한다.</span>
        </h2>
      </div>
      <div class="flex gap-4">
        <a href={`${base}insights/`} class="bg-white dark:bg-[#1b1b1d] border border-black dark:border-[#353437] text-black dark:text-white px-6 md:px-8 py-3 md:py-4 text-xs font-bold tracking-widest hover:bg-black hover:text-white dark:hover:bg-[#FBE830] dark:hover:text-black transition-all duration-300 inline-block">
          인사이트 보기
        </a>
        <a href={`${base}gallery/`} class="bg-[#FBE830] text-black px-6 md:px-8 py-3 md:py-4 text-xs font-bold tracking-widest transition-transform duration-150 active:scale-95 shadow-md inline-block">
          갤러리 보기
        </a>
      </div>
    </div>
    <div class="absolute left-0 bottom-0 text-[14rem] md:text-[18rem] font-black text-black/5 dark:text-white/5 leading-none select-none -translate-x-20 translate-y-20 pointer-events-none">
      AAA
    </div>
  </section>

  <script is:inline>
    function openMemberModal(card) {
      const name = card.dataset.name;
      const role = card.dataset.role;
      const desc = card.dataset.desc;
      const avatar = card.dataset.avatar;
      const linkedin = card.dataset.linkedin;
      const keywords = JSON.parse(card.dataset.keywords || '[]');
      const weeks = JSON.parse(card.dataset.weeks || '[]');

      document.getElementById('mm-name').textContent = name;
      document.getElementById('mm-role').textContent = role;
      document.getElementById('mm-desc').textContent = desc;

      // Avatar
      const avatarWrap = document.getElementById('mm-avatar-wrap');
      if (avatar) {
        avatarWrap.innerHTML = `<img src="${avatar}" alt="${name}" class="w-14 h-14 rounded-full object-cover border-2 border-slate-200 dark:border-[#353437]" />`;
      } else {
        avatarWrap.innerHTML = `<div class="w-14 h-14 bg-slate-100 dark:bg-[#252527] rounded-full flex items-center justify-center"><span class="text-lg font-bold text-slate-400 dark:text-gray-500">${name.charAt(0)}</span></div>`;
      }

      // LinkedIn
      const linkedinWrap = document.getElementById('mm-linkedin-wrap');
      if (linkedin) {
        document.getElementById('mm-linkedin').href = linkedin;
        linkedinWrap.classList.remove('hidden');
      } else {
        linkedinWrap.classList.add('hidden');
      }

      // Keywords
      const kwWrap = document.getElementById('mm-keywords-wrap');
      const kwEl = document.getElementById('mm-keywords');
      if (keywords.length > 0) {
        kwEl.innerHTML = keywords.map(kw =>
          `<span class="text-[11px] px-2.5 py-1 rounded-full bg-[#FBE830]/10 text-[#b8960a] dark:text-[#FBE830] font-medium border border-[#FBE830]/20">${kw}</span>`
        ).join('');
        kwWrap.classList.remove('hidden');
      } else {
        kwWrap.classList.add('hidden');
      }

      // Weeks
      const weeksWrap = document.getElementById('mm-weeks-wrap');
      const weeksEl = document.getElementById('mm-weeks');
      if (weeks.length > 0) {
        weeksEl.innerHTML = weeks.map(w =>
          `<div class="flex gap-3 p-3 rounded-lg bg-slate-50 dark:bg-[#141418] border border-slate-100 dark:border-[#2a2a30]">
            <span class="text-xs font-black text-[#FBE830] whitespace-nowrap mt-0.5">W${String(w.week).padStart(2, '0')}</span>
            <div class="min-w-0">
              <p class="text-xs font-bold text-black dark:text-white mb-0.5 truncate">${w.title}</p>
              <p class="text-[11px] text-slate-500 dark:text-gray-400 leading-relaxed line-clamp-2">${w.summary}</p>
            </div>
          </div>`
        ).join('');
        weeksWrap.classList.remove('hidden');
      } else {
        weeksWrap.classList.add('hidden');
      }

      document.getElementById('member-modal').classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeMemberModal() {
      document.getElementById('member-modal').classList.add('hidden');
      document.body.style.overflow = '';
    }

    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.member-card').forEach(card => {
        card.addEventListener('click', () => openMemberModal(card));
      });
    });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMemberModal(); });
  </script>
</Layout>
