---
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

const members = ['다다', '비비안', '띵끄', '잽', '흐민', '에밀리', '다니', '오웬', '젬마'];

const collections = {
  gallery: {
    label: '갤러리',
    path: 'src/content/gallery',
    fields: [
      { key: 'name', label: '프로젝트명', type: 'text' },
      { key: 'maker', label: '제작자', type: 'select', options: members },
      { key: 'thumbnail', label: '썸네일 이모지', type: 'text', placeholder: '🚀' },
      { key: 'link', label: '링크', type: 'text', placeholder: 'https://...' },
      { key: 'week', label: '주차', type: 'number' },
    ]
  },
  tools: {
    label: '도구 모음',
    path: 'src/content/tools',
    fields: [
      { key: 'name', label: '도구명', type: 'text' },
      { key: 'category', label: '카테고리', type: 'multiselect', options: ['자동화', '콘텐츠', '분석', '생산성', '디자인'] },
      { key: 'type', label: '유형', type: 'select', options: ['Claude Code 스킬', 'Obsidian 플러그인', 'CLI 도구', '웹 도구', 'MCP 서버'] },
      { key: 'difficulty', label: '난이도', type: 'select', options: ['초급', '중급', '고급'] },
      { key: 'link', label: '링크', type: 'text', placeholder: 'https://...' },
      { key: 'added_by', label: '등록자', type: 'select', options: members },
    ]
  },
  insights: {
    label: '인사이트',
    path: 'src/content/insights',
    fields: [
      { key: 'member', label: '작성자', type: 'select', options: members },
      { key: 'summary', label: '요약', type: 'textarea' },
      { key: 'keywords', label: '키워드 (쉼표 구분)', type: 'tags' },
    ]
  },
  analysis: {
    label: '분석',
    path: 'src/content/analysis',
    fields: [
      { key: 'week', label: '주차', type: 'number' },
      { key: 'date', label: '날짜', type: 'text', placeholder: '2026-04-12' },
      { key: 'total_submissions', label: '제출 인원', type: 'number' },
      { key: 'tags', label: '태그 (쉼표 구분)', type: 'tags' },
    ]
  },
  proposals: {
    label: '제안',
    path: 'src/content/proposals',
    fields: [
      { key: 'tags', label: '태그 (쉼표 구분)', type: 'tags' },
      { key: 'status', label: '상태', type: 'select', options: ['제안', '검토중', '채택', '완료', '보류'] },
      { key: 'last_updated', label: '최종 수정일', type: 'text', placeholder: '2026-04-12' },
    ]
  }
};
---
<Layout title="어드민 - AAA TEAM">
  <!-- Hero Banner -->
  <section class="pt-14 md:pt-16" style="background: linear-gradient(135deg, rgba(251,232,48,0.08) 0%, rgba(251,232,48,0.15) 40%, rgba(200,240,200,0.1) 100%);">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 pt-8 md:pt-10 pb-8 md:pb-10">
      <h1 class="font-headline text-2xl md:text-3xl font-extrabold tracking-tight text-black dark:text-white mb-2">어드민</h1>
      <p class="text-sm md:text-base text-slate-600 dark:text-gray-400">콘텐츠 <strong class="text-black dark:text-white">frontmatter</strong>를 GUI로 편집합니다.</p>
    </div>
  </section>

  <!-- Token Setup -->
  <div id="token-setup" class="bg-white dark:bg-[#131315] border-b border-slate-100 dark:border-[#353437]">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 py-4 flex items-center gap-3">
      <span class="material-symbols-outlined text-slate-400 text-lg">key</span>
      <input id="token-input" type="password" placeholder="GitHub Personal Access Token" class="flex-1 px-3 py-2 bg-slate-50 dark:bg-[#1b1b1d] border border-slate-200 dark:border-[#353437] rounded-lg text-sm text-black dark:text-white focus:outline-none focus:border-[#FBE830]" />
      <button id="token-save" class="bg-[#FBE830] text-black font-bold text-sm px-4 py-2 rounded-lg hover:shadow-md transition-all">연결</button>
      <button id="token-reset" class="hidden text-xs text-slate-400 hover:text-red-500 transition-colors px-3 py-2" onclick="localStorage.removeItem('gh_token'); location.reload();">토큰 초기화</button>
      <span id="token-status" class="text-xs text-slate-400 hidden">✓ 연결됨</span>
    </div>
  </div>

  <!-- Tab Filter -->
  <section class="bg-white dark:bg-[#131315] border-b border-slate-100 dark:border-[#353437] sticky top-14 md:top-16 z-40">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12">
      <div class="flex items-center gap-2 py-3">
        <button class="tab-btn active text-sm font-bold px-5 py-2 rounded-full transition-all" data-collection="gallery">갤러리</button>
        <button class="tab-btn text-sm font-medium px-5 py-2 rounded-full transition-all" data-collection="tools">도구 모음</button>
        <button class="tab-btn text-sm font-medium px-5 py-2 rounded-full transition-all" data-collection="insights">인사이트</button>
        <button class="tab-btn text-sm font-medium px-5 py-2 rounded-full transition-all" data-collection="analysis">분석</button>
        <button class="tab-btn text-sm font-medium px-5 py-2 rounded-full transition-all" data-collection="proposals">제안</button>
        <div class="flex-1"></div>
        <button id="create-btn" class="hidden items-center gap-1.5 text-sm font-bold px-4 py-2 rounded-full bg-black dark:bg-white text-white dark:text-black hover:shadow-md transition-all" onclick="openCreateModal()">
          <span class="material-symbols-outlined text-base">add</span>
          새 파일
        </button>
      </div>
    </div>
  </section>

  <!-- Content Area -->
  <section class="bg-white dark:bg-[#131315]">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 pt-8 pb-24">
      <!-- Loading -->
      <div id="loading" class="hidden text-center py-12">
        <span class="material-symbols-outlined text-slate-300 text-3xl animate-spin">progress_activity</span>
        <p class="text-sm text-slate-400 mt-2">로딩 중...</p>
      </div>

      <!-- No Token -->
      <div id="no-token" class="text-center py-16">
        <span class="material-symbols-outlined text-slate-300 dark:text-gray-600 text-5xl block mb-4">lock</span>
        <p class="text-slate-400 dark:text-gray-500">GitHub 토큰을 입력해주세요.</p>
        <p class="text-xs text-slate-300 dark:text-gray-600 mt-2">Settings → Developer settings → Personal access tokens → repo 권한</p>
      </div>

      <!-- File List -->
      <div id="file-list" class="hidden space-y-2"></div>

      <!-- Edit Modal -->
      <div id="edit-modal" class="fixed inset-0 z-50 hidden">
        <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeEditor()"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-lg max-h-[80vh] overflow-y-auto bg-white dark:bg-[#1b1b1d] rounded-2xl shadow-2xl p-6 md:p-8">
          <div class="flex items-center justify-between mb-6">
            <h2 id="edit-title" class="font-headline text-lg font-bold text-black dark:text-white"></h2>
            <button onclick="closeEditor()" class="text-slate-400 hover:text-black dark:hover:text-white">
              <span class="material-symbols-outlined">close</span>
            </button>
          </div>
          <div id="edit-fields" class="space-y-4"></div>
          <div class="flex gap-3 mt-6 pt-4 border-t border-slate-100 dark:border-[#353437]">
            <button id="save-btn" onclick="saveFile()" class="flex-1 bg-[#FBE830] text-black font-bold py-3 rounded-lg text-sm hover:shadow-lg transition-all">저장</button>
            <button onclick="closeEditor()" class="px-6 py-3 border border-slate-200 dark:border-[#353437] rounded-lg text-sm text-slate-500 hover:text-black dark:hover:text-white transition-colors">취소</button>
          </div>
          <div id="save-status" class="hidden mt-3 p-3 rounded-lg text-sm text-center"></div>
          <div class="mt-4 pt-4 border-t border-slate-100 dark:border-[#353437]">
            <button id="delete-btn" onclick="deleteFile()" class="w-full flex items-center justify-center gap-1.5 py-2.5 rounded-lg text-sm text-red-400 hover:text-white hover:bg-red-500 border border-red-200 dark:border-red-900 hover:border-red-500 transition-all">
              <span class="material-symbols-outlined text-base">delete</span>
              파일 삭제
            </button>
          </div>
        </div>
      </div>

      <!-- Create Modal -->
      <div id="create-modal" class="fixed inset-0 z-50 hidden">
        <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeCreateModal()"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-md bg-white dark:bg-[#1b1b1d] rounded-2xl shadow-2xl p-6 md:p-8">
          <div class="flex items-center justify-between mb-6">
            <h2 class="font-headline text-lg font-bold text-black dark:text-white">새 파일 만들기</h2>
            <button onclick="closeCreateModal()" class="text-slate-400 hover:text-black dark:hover:text-white">
              <span class="material-symbols-outlined">close</span>
            </button>
          </div>
          <div class="space-y-4">
            <div>
              <label class="block text-xs font-bold text-slate-600 dark:text-gray-400 uppercase tracking-wider mb-1.5">파일명 (.md 자동 추가)</label>
              <input id="create-filename" type="text" placeholder="예: Week_04_분석" class="w-full px-3 py-2.5 bg-slate-50 dark:bg-[#252527] border border-slate-200 dark:border-[#353437] rounded-lg text-sm text-black dark:text-white focus:outline-none focus:border-[#FBE830]" />
            </div>
            <div id="create-fields" class="space-y-4"></div>
          </div>
          <div class="flex gap-3 mt-6 pt-4 border-t border-slate-100 dark:border-[#353437]">
            <button id="create-save-btn" onclick="createFile()" class="flex-1 bg-black dark:bg-white text-white dark:text-black font-bold py-3 rounded-lg text-sm hover:shadow-lg transition-all">생성</button>
            <button onclick="closeCreateModal()" class="px-6 py-3 border border-slate-200 dark:border-[#353437] rounded-lg text-sm text-slate-500 hover:text-black dark:hover:text-white transition-colors">취소</button>
          </div>
          <div id="create-status" class="hidden mt-3 p-3 rounded-lg text-sm text-center"></div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .ms-chip {
      background: transparent;
      color: #6b7280;
      border-color: #e5e7eb;
    }
    .ms-chip:hover { border-color: #FBE830; color: #000; }
    .ms-chip.active { background: #FBE830; color: #000; border-color: #FBE830; font-weight: 700; }
    :global(.dark) .ms-chip { border-color: #353437; color: #9ca3af; }
    :global(.dark) .ms-chip:hover { border-color: #FBE830; color: #fff; }
    :global(.dark) .ms-chip.active { background: #FBE830; color: #000; border-color: #FBE830; }

    .tab-btn {
      background: transparent;
      color: #6b7280;
      border: 1px solid #e5e7eb;
    }
    .tab-btn:hover { border-color: #FBE830; color: #000; }
    .tab-btn.active { background: #FBE830; color: #000; font-weight: 700; border-color: #FBE830; }
    :global(.dark) .tab-btn { border-color: #353437; color: #9ca3af; }
    :global(.dark) .tab-btn:hover { border-color: #FBE830; color: #fff; }
    :global(.dark) .tab-btn.active { background: #FBE830; color: #000; border-color: #FBE830; }
  </style>

  <script is:inline define:vars={{ collections }}>
    const OWNER = 'selfishclub';
    const REPO = 'aaa-admin';
    let currentCollection = 'gallery';
    let currentFile = null;
    let currentSha = null;
    let currentBody = '';

    function getToken() { return localStorage.getItem('gh_token') || ''; }

    async function api(endpoint, options = {}) {
      const res = await fetch(`https://api.github.com/repos/${OWNER}/${REPO}/${endpoint}`, {
        ...options,
        headers: {
          'Authorization': `token ${getToken()}`,
          'Accept': 'application/vnd.github.v3+json',
          ...(options.headers || {}),
          ...(options.body ? { 'Content-Type': 'application/json' } : {}),
        }
      });
      if (!res.ok) throw new Error(`GitHub API ${res.status}`);
      return res.json();
    }

    function parseFrontmatter(content) {
      const match = content.match(/^---\n([\s\S]*?)\n---\n?([\s\S]*)$/);
      if (!match) return { data: {}, body: content };
      const data = {};
      const lines = match[1].split('\n');
      let currentKey = null;
      let currentList = null;

      for (const line of lines) {
        if (line.match(/^\s+-\s+/) && currentKey) {
          const val = line.replace(/^\s+-\s+/, '').trim();
          if (!currentList) currentList = [];
          currentList.push(val);
          data[currentKey] = currentList;
          continue;
        }
        const m = line.match(/^([a-zA-Z_]\w*):\s*(.*)$/);
        if (m) {
          currentList = null;
          currentKey = m[1];
          let val = m[2].trim();

          if (val === '' || val === '~' || val === 'null') {
            data[currentKey] = '';
            continue;
          }
          if (val.startsWith('[') && val.endsWith(']')) {
            val = val.slice(1, -1).split(',').map(s => s.trim().replace(/^["']|["']$/g, ''));
          } else if (val.startsWith('"') && val.endsWith('"')) {
            val = val.slice(1, -1);
          } else if (!isNaN(val) && val !== '') {
            val = Number(val);
          }
          data[currentKey] = val;
          currentList = null;
        }
      }
      return { data, body: match[2] };
    }

    function buildFrontmatter(data, body) {
      let yaml = '---\n';
      for (const [key, val] of Object.entries(data)) {
        if (val === undefined || val === null || val === '') continue;
        if (Array.isArray(val)) {
          if (val.length === 0) continue;
          yaml += `${key}:\n`;
          for (const item of val) {
            yaml += `  - ${item}\n`;
          }
        } else if (typeof val === 'number') {
          yaml += `${key}: ${val}\n`;
        } else {
          yaml += `${key}: "${val}"\n`;
        }
      }
      yaml += '---\n';
      return yaml + (body || '');
    }

    function safeDecodeUri(str) {
      try { return decodeURIComponent(str); } catch { return str; }
    }

    function renderFieldHtml(field, val) {
      if (field.type === 'multiselect') {
        const selected = Array.isArray(val) ? val : (val ? [val] : []);
        const chips = (field.options || []).map(o => {
          const active = selected.includes(o);
          return `<button type="button" data-option="${o}" class="ms-chip ${active ? 'active' : ''} px-3 py-1.5 rounded-full text-xs font-medium border transition-all cursor-pointer">${o}</button>`;
        }).join('');
        return `
          <div>
            <label class="block text-xs font-bold text-slate-600 dark:text-gray-400 uppercase tracking-wider mb-1.5">${field.label}</label>
            <div data-key="${field.key}" data-type="multiselect" class="admin-input flex flex-wrap gap-2 p-2.5 bg-slate-50 dark:bg-[#252527] border border-slate-200 dark:border-[#353437] rounded-lg min-h-[42px]">
              ${chips}
            </div>
          </div>`;
      }
      if (field.type === 'select') {
        const opts = (field.options || []).map(o =>
          `<option value="${o}" ${val === o ? 'selected' : ''}>${o}</option>`
        ).join('');
        return `
          <div>
            <label class="block text-xs font-bold text-slate-600 dark:text-gray-400 uppercase tracking-wider mb-1.5">${field.label}</label>
            <select data-key="${field.key}" class="admin-input w-full px-3 py-2.5 bg-slate-50 dark:bg-[#252527] border border-slate-200 dark:border-[#353437] rounded-lg text-sm text-black dark:text-white focus:outline-none focus:border-[#FBE830]">
              <option value="">선택...</option>
              ${opts}
            </select>
          </div>`;
      }
      if (field.type === 'textarea') {
        return `
          <div>
            <label class="block text-xs font-bold text-slate-600 dark:text-gray-400 uppercase tracking-wider mb-1.5">${field.label}</label>
            <textarea data-key="${field.key}" rows="3" class="admin-input w-full px-3 py-2.5 bg-slate-50 dark:bg-[#252527] border border-slate-200 dark:border-[#353437] rounded-lg text-sm text-black dark:text-white focus:outline-none focus:border-[#FBE830] resize-none">${val}</textarea>
          </div>`;
      }
      return `
        <div>
          <label class="block text-xs font-bold text-slate-600 dark:text-gray-400 uppercase tracking-wider mb-1.5">${field.label}</label>
          <input data-key="${field.key}" type="${field.type === 'number' ? 'number' : 'text'}" value="${val}" placeholder="${field.placeholder || ''}"
            class="admin-input w-full px-3 py-2.5 bg-slate-50 dark:bg-[#252527] border border-slate-200 dark:border-[#353437] rounded-lg text-sm text-black dark:text-white focus:outline-none focus:border-[#FBE830]" />
        </div>`;
    }

    function collectFieldData(selector) {
      const col = collections[currentCollection];
      const data = {};
      document.querySelectorAll(selector).forEach(input => {
        const key = input.dataset.key;
        if (input.dataset.type === 'multiselect') {
          const selected = Array.from(input.querySelectorAll('.ms-chip.active')).map(c => c.dataset.option);
          if (selected.length > 0) data[key] = selected;
          return;
        }
        let val = input.value.trim();
        const field = col.fields.find(f => f.key === key);
        if (field?.type === 'number' && val) val = Number(val);
        if (field?.type === 'tags' && val) val = val.split(',').map(s => s.trim()).filter(Boolean);
        if (val !== '' && val !== null) data[key] = val;
      });
      return data;
    }

    // Multiselect chip toggle
    document.addEventListener('click', (e) => {
      if (e.target.classList.contains('ms-chip')) {
        e.target.classList.toggle('active');
      }
    });

    // Token setup
    document.getElementById('token-save').addEventListener('click', () => {
      const token = document.getElementById('token-input').value.trim();
      if (!token) return;
      localStorage.setItem('gh_token', token);
      document.getElementById('token-input').value = '';
      initAdmin();
    });

    // Tab switching
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentCollection = btn.dataset.collection;
        loadFiles();
      });
    });

    async function loadFiles() {
      const listEl = document.getElementById('file-list');
      const loadingEl = document.getElementById('loading');
      listEl.classList.add('hidden');
      loadingEl.classList.remove('hidden');

      try {
        const col = collections[currentCollection];
        const files = await api(`contents/${col.path}`);
        const mdFiles = files.filter(f => f.name.endsWith('.md'));

        listEl.innerHTML = mdFiles.map(f => `
          <div class="file-item flex items-center gap-4 px-5 py-3.5 rounded-lg hover:bg-slate-50 dark:hover:bg-[#1b1b1d] transition-all cursor-pointer border border-transparent hover:border-[#FBE830]/30 group"
               data-path="${f.path}" data-sha="${f.sha}">
            <span class="material-symbols-outlined text-slate-400 group-hover:text-[#FBE830] text-lg">description</span>
            <span class="flex-1 text-sm font-medium text-black dark:text-white group-hover:text-[#b8960a] dark:group-hover:text-[#FBE830] truncate">${safeDecodeUri(f.name.replace('.md', ''))}</span>
            <span class="material-symbols-outlined text-slate-300 text-sm">edit</span>
          </div>
        `).join('');

        listEl.querySelectorAll('.file-item').forEach(item => {
          item.addEventListener('click', () => openEditor(item.dataset.path));
        });

        loadingEl.classList.add('hidden');
        listEl.classList.remove('hidden');
      } catch (e) {
        loadingEl.classList.add('hidden');
        listEl.innerHTML = '<p class="text-red-500 text-sm text-center py-8">파일 로드 실패: ' + e.message + '</p>';
        listEl.classList.remove('hidden');
      }
    }

    async function openEditor(path) {
      const col = collections[currentCollection];
      const file = await api(`contents/${path}`);
      const decoded = new TextDecoder().decode(Uint8Array.from(atob(file.content.replace(/\n/g, '')), c => c.charCodeAt(0)));
      const { data, body } = parseFrontmatter(decoded);
      currentFile = path;
      currentSha = file.sha;
      currentBody = body;

      const fileName = path.split('/').pop().replace('.md', '');
      document.getElementById('edit-title').textContent = safeDecodeUri(fileName);

      const fieldsEl = document.getElementById('edit-fields');
      fieldsEl.innerHTML = col.fields.map(field => {
        let val = data[field.key] || '';
        if ((field.type === 'tags' || field.key === 'keywords') && Array.isArray(val)) {
          val = val.join(', ');
        }
        return renderFieldHtml(field, val);
      }).join('');

      document.getElementById('save-status').classList.add('hidden');
      document.getElementById('edit-modal').classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    window.closeEditor = function() {
      document.getElementById('edit-modal').classList.add('hidden');
      document.body.style.overflow = '';
    };

    window.saveFile = async function() {
      const btn = document.getElementById('save-btn');
      const statusEl = document.getElementById('save-status');
      btn.textContent = '저장 중...';
      btn.disabled = true;

      try {
        const data = collectFieldData('#edit-fields .admin-input');
        const newContent = buildFrontmatter(data, currentBody);
        const encoded = btoa(unescape(encodeURIComponent(newContent)));

        await api(`contents/${currentFile}`, {
          method: 'PUT',
          body: JSON.stringify({
            message: `admin: ${currentFile.split('/').pop()} frontmatter 수정`,
            content: encoded,
            sha: currentSha,
          })
        });

        statusEl.className = 'mt-3 p-3 rounded-lg text-sm text-center bg-[#FBE830]/10 text-[#b8960a] border border-[#FBE830]/30';
        statusEl.textContent = '✓ 저장 완료! Vercel이 자동 재배포합니다.';
        statusEl.classList.remove('hidden');
        btn.textContent = '저장';
        btn.disabled = false;

        setTimeout(() => { closeEditor(); loadFiles(); }, 1500);
      } catch (e) {
        statusEl.className = 'mt-3 p-3 rounded-lg text-sm text-center bg-red-50 text-red-500 border border-red-200';
        statusEl.textContent = '저장 실패: ' + e.message;
        statusEl.classList.remove('hidden');
        btn.textContent = '저장';
        btn.disabled = false;
      }
    };

    window.deleteFile = async function() {
      if (!currentFile) return;
      const fileName = currentFile.split('/').pop();
      if (!confirm(`"${safeDecodeUri(fileName)}" 파일을 삭제하시겠습니까?\n이 작업은 되돌릴 수 없습니다.`)) return;

      const btn = document.getElementById('delete-btn');
      const statusEl = document.getElementById('save-status');
      btn.textContent = '삭제 중...';
      btn.disabled = true;

      try {
        await api(`contents/${currentFile}`, {
          method: 'DELETE',
          body: JSON.stringify({
            message: `admin: ${fileName} 삭제`,
            sha: currentSha,
          })
        });

        statusEl.className = 'mt-3 p-3 rounded-lg text-sm text-center bg-red-50 dark:bg-red-900/20 text-red-500 border border-red-200 dark:border-red-900';
        statusEl.textContent = '✓ 삭제 완료.';
        statusEl.classList.remove('hidden');
        btn.textContent = '파일 삭제';
        btn.disabled = false;

        setTimeout(() => { closeEditor(); loadFiles(); }, 1200);
      } catch (e) {
        statusEl.className = 'mt-3 p-3 rounded-lg text-sm text-center bg-red-50 text-red-500 border border-red-200';
        statusEl.textContent = '삭제 실패: ' + e.message;
        statusEl.classList.remove('hidden');
        btn.textContent = '파일 삭제';
        btn.disabled = false;
      }
    };

    window.openCreateModal = function() {
      const col = collections[currentCollection];
      document.getElementById('create-filename').value = '';

      const fieldsEl = document.getElementById('create-fields');
      fieldsEl.innerHTML = col.fields.map(field => renderFieldHtml(field, '')).join('');

      document.getElementById('create-status').classList.add('hidden');
      document.getElementById('create-modal').classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      document.getElementById('create-filename').focus();
    };

    window.closeCreateModal = function() {
      document.getElementById('create-modal').classList.add('hidden');
      document.body.style.overflow = '';
    };

    window.createFile = async function() {
      const filename = document.getElementById('create-filename').value.trim();
      const statusEl = document.getElementById('create-status');
      const btn = document.getElementById('create-save-btn');

      if (!filename) {
        statusEl.className = 'mt-3 p-3 rounded-lg text-sm text-center bg-red-50 text-red-500 border border-red-200';
        statusEl.textContent = '파일명을 입력해주세요.';
        statusEl.classList.remove('hidden');
        return;
      }

      btn.textContent = '생성 중...';
      btn.disabled = true;

      try {
        const col = collections[currentCollection];
        const data = collectFieldData('#create-fields .admin-input');
        const content = buildFrontmatter(data, '\n');
        const encoded = btoa(unescape(encodeURIComponent(content)));
        const filePath = `${col.path}/${filename}.md`;

        await api(`contents/${filePath}`, {
          method: 'PUT',
          body: JSON.stringify({
            message: `admin: ${filename}.md 생성`,
            content: encoded,
          })
        });

        statusEl.className = 'mt-3 p-3 rounded-lg text-sm text-center bg-[#FBE830]/10 text-[#b8960a] border border-[#FBE830]/30';
        statusEl.textContent = '✓ 생성 완료!';
        statusEl.classList.remove('hidden');
        btn.textContent = '생성';
        btn.disabled = false;

        setTimeout(() => { closeCreateModal(); loadFiles(); }, 1200);
      } catch (e) {
        statusEl.className = 'mt-3 p-3 rounded-lg text-sm text-center bg-red-50 text-red-500 border border-red-200';
        statusEl.textContent = '생성 실패: ' + e.message;
        statusEl.classList.remove('hidden');
        btn.textContent = '생성';
        btn.disabled = false;
      }
    };

    function initAdmin() {
      if (getToken()) {
        document.getElementById('no-token').classList.add('hidden');
        document.getElementById('token-input').style.display = 'none';
        document.getElementById('token-save').style.display = 'none';
        document.getElementById('token-status').classList.remove('hidden');
        document.getElementById('token-reset').classList.remove('hidden');
        document.getElementById('create-btn').classList.remove('hidden');
        document.getElementById('create-btn').classList.add('flex');
        loadFiles();
      }
    }

    document.addEventListener('DOMContentLoaded', initAdmin);
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') {
        closeEditor();
        closeCreateModal();
      }
    });
  </script>
</Layout>
