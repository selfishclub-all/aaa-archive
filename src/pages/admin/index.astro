---
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

const members = ['다다', '비비안', '띵끄', '잽', '흐민', '에밀리', '다니', '오웬', '젬마'];

const collections = {
  gallery: {
    label: '갤러리',
    path: 'src/content/gallery',
    fields: [
      { key: 'name', label: '프로젝트명', type: 'text' },
      { key: 'maker', label: '제작자', type: 'select', options: members },
      { key: 'thumbnail', label: '썸네일 이미지', type: 'image', sizeHint: '600x320px (2:1 비율)', uploadPath: 'public/images/gallery' },
      { key: 'link', label: '링크', type: 'text', placeholder: 'https://...' },
      { key: 'week', label: '주차', type: 'number' },
    ]
  },
  members: {
    label: '멤버',
    path: 'src/content/members',
    fields: [
      { key: 'name', label: '이름', type: 'text' },
      { key: 'role', label: '역할', type: 'select', options: ['Builder', 'Organizer', 'Mentor'] },
      { key: 'desc', label: '한줄소개', type: 'textarea' },
      { key: 'linkedin', label: 'LinkedIn 프로필 링크', type: 'text', placeholder: 'https://linkedin.com/in/...' },
      { key: 'avatar', label: '프로필 이미지', type: 'image', sizeHint: '200x200px (정사각형)', uploadPath: 'public/images/members' },
    ]
  },
  tools: {
    label: '도구 모음',
    path: 'src/content/tools',
    hasBodyEditor: true,
    fields: [
      { key: 'name', label: '도구명', type: 'text' },
      { key: 'category', label: '카테고리', type: 'managed-tags', storageKey: 'tool_categories', defaults: ['자동화', '콘텐츠', '분석', '생산성', '디자인'] },
      { key: 'link', label: '링크', type: 'text', placeholder: 'https://...' },
      { key: 'added_by', label: '등록자', type: 'select', options: members },
    ]
  },
  insights: {
    label: '인사이트',
    path: 'src/content/insights',
    hasBodyEditor: true,
    fields: [
      { key: 'member', label: '작성자', type: 'select', options: members },
      { key: 'summary', label: '요약', type: 'textarea' },
      { key: 'keywords', label: '키워드 (최대 3개, 기존 키워드 우선 활용)', type: 'managed-tags', storageKey: 'insight_keywords', defaults: [], maxTags: 3 },
    ]
  },
  analysis: {
    label: '분석',
    path: 'src/content/analysis',
    hasBodyEditor: true,
    fields: [
      { key: 'week', label: '주차', type: 'number' },
      { key: 'title', label: '주제', type: 'text', placeholder: '예: 만들었다에서 운영한다로' },
      { key: 'description', label: '설명', type: 'textarea' },
      { key: 'date', label: '날짜', type: 'text', placeholder: '2026-04-12' },
      { key: 'total_submissions', label: '제출 인원', type: 'number' },
      { key: 'tags', label: '태그 (쉼표 구분)', type: 'tags' },
    ]
  },
  proposals: {
    label: '제안',
    path: 'src/content/proposals',
    hasBodyEditor: true,
    fields: [
      { key: 'tags', label: '태그 (쉼표 구분)', type: 'tags' },
      { key: 'status', label: '상태', type: 'select', options: ['제안', '검토중', '채택', '완료', '보류'] },
      { key: 'last_updated', label: '최종 수정일', type: 'text', placeholder: '2026-04-12' },
    ]
  }
};
---
<Layout title="어드민 - AAA TEAM">
  <!-- Admin Override: 강제 다크 배경 -->
  <style is:inline>
    .admin-shell { background: #0c0c0e !important; color: #e5e1e4 !important; min-height: 100vh; }
    .admin-shell header { background: rgba(12,12,14,0.9) !important; border-color: #1e1e22 !important; }
    .admin-shell header a, .admin-shell header button, .admin-shell header span { color: #71717a !important; }
    .admin-shell header a:hover, .admin-shell header button:hover { color: #a5b4fc !important; }
  </style>
  <div class="admin-shell">

  <!-- Hero Banner -->
  <section class="pt-14 md:pt-16" style="background: linear-gradient(135deg, #0c0c0e 0%, #1a1a2e 50%, #16132b 100%);">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 pt-8 md:pt-10 pb-8 md:pb-10">
      <div class="flex items-center gap-3 mb-2">
        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md text-[10px] font-bold uppercase tracking-widest bg-indigo-500/15 text-indigo-400 border border-indigo-500/20">Admin</span>
      </div>
      <h1 class="font-headline text-2xl md:text-3xl font-extrabold tracking-tight text-white mb-2">콘텐츠 관리</h1>
      <p class="text-sm md:text-base text-slate-400">GitHub API로 <strong class="text-indigo-300">frontmatter</strong>를 직접 편집합니다.</p>
    </div>
  </section>

  <!-- Token Setup -->
  <div id="token-setup" class="bg-[#0c0c0e] border-b border-[#1e1e22]">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 py-4 flex items-center gap-3">
      <span class="material-symbols-outlined text-indigo-400/60 text-lg">key</span>
      <input id="token-input" type="password" placeholder="GitHub Personal Access Token" class="flex-1 px-3 py-2 bg-[#141418] border border-[#2a2a30] rounded-lg text-sm text-white focus:outline-none focus:border-indigo-500" />
      <button id="token-save" class="bg-indigo-500 text-white font-bold text-sm px-4 py-2 rounded-lg hover:bg-indigo-400 hover:shadow-md hover:shadow-indigo-500/20 transition-all">연결</button>
      <button id="token-reset" class="hidden text-xs text-slate-500 hover:text-red-400 transition-colors px-3 py-2" onclick="localStorage.removeItem('gh_token'); location.reload();">토큰 초기화</button>
      <span id="token-status" class="text-xs text-indigo-400 hidden">연결됨</span>
    </div>
  </div>

  <!-- Tab Filter -->
  <section class="bg-[#0c0c0e] border-b border-[#1e1e22] sticky top-14 md:top-16 z-40">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12">
      <div class="flex items-center gap-2 py-3 overflow-x-auto">
        <button class="tab-btn active text-sm font-bold px-5 py-2 rounded-full transition-all whitespace-nowrap" data-collection="gallery">갤러리</button>
        <button class="tab-btn text-sm font-medium px-5 py-2 rounded-full transition-all whitespace-nowrap" data-collection="members">멤버</button>
        <button class="tab-btn text-sm font-medium px-5 py-2 rounded-full transition-all whitespace-nowrap" data-collection="tools">도구 모음</button>
        <button class="tab-btn text-sm font-medium px-5 py-2 rounded-full transition-all whitespace-nowrap" data-collection="insights">인사이트</button>
        <button class="tab-btn text-sm font-medium px-5 py-2 rounded-full transition-all whitespace-nowrap" data-collection="analysis">분석</button>
        <button class="tab-btn text-sm font-medium px-5 py-2 rounded-full transition-all whitespace-nowrap" data-collection="proposals">제안</button>
        <div class="flex-1"></div>
        <button id="create-btn" class="hidden items-center gap-1.5 text-sm font-bold px-4 py-2 rounded-full bg-indigo-500 text-white hover:bg-indigo-400 hover:shadow-md hover:shadow-indigo-500/20 transition-all whitespace-nowrap" onclick="openCreateModal()">
          <span class="material-symbols-outlined text-base">add</span>
          새 파일
        </button>
      </div>
    </div>
  </section>

  <!-- Content Area -->
  <section class="bg-[#0c0c0e]">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 pt-8 pb-24">
      <!-- Loading -->
      <div id="loading" class="hidden text-center py-12">
        <span class="material-symbols-outlined text-indigo-400/40 text-3xl animate-spin">progress_activity</span>
        <p class="text-sm text-slate-500 mt-2">로딩 중...</p>
      </div>

      <!-- No Token -->
      <div id="no-token" class="text-center py-16">
        <span class="material-symbols-outlined text-[#2a2a30] text-5xl block mb-4">lock</span>
        <p class="text-slate-500">GitHub 토큰을 입력해주세요.</p>
        <p class="text-xs text-slate-600 mt-2">Settings → Developer settings → Personal access tokens → repo 권한</p>
      </div>

      <!-- File List -->
      <div id="file-list" class="hidden space-y-2"></div>

      <!-- Edit Modal -->
      <div id="edit-modal" class="fixed inset-0 z-50 hidden">
        <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="closeEditor()"></div>
        <div id="edit-modal-inner" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-lg max-h-[85vh] overflow-y-auto bg-[#141418] border border-[#2a2a30] rounded-2xl shadow-2xl shadow-black/50 p-6 md:p-8 transition-all">
          <div class="flex items-center justify-between mb-6">
            <h2 id="edit-title" class="font-headline text-lg font-bold text-white"></h2>
            <button onclick="closeEditor()" class="text-slate-500 hover:text-white">
              <span class="material-symbols-outlined">close</span>
            </button>
          </div>
          <div id="edit-fields" class="space-y-4"></div>
          <!-- Body Editor (마크다운 + 미리보기) -->
          <div id="body-editor-wrap" class="hidden mt-6 pt-4 border-t border-[#2a2a30]">
            <div class="flex items-center justify-between mb-2">
              <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider">본문</label>
              <div class="flex items-center gap-2">
                <div class="flex gap-1">
                  <button type="button" onclick="insertMd('## ')" class="text-xs px-2 py-1 rounded bg-[#1e1e22] text-slate-400 hover:text-white transition-colors" title="제목">H2</button>
                  <button type="button" onclick="insertMd('### ')" class="text-xs px-2 py-1 rounded bg-[#1e1e22] text-slate-400 hover:text-white transition-colors" title="소제목">H3</button>
                  <button type="button" onclick="insertMd('**', '**')" class="text-xs px-2 py-1 rounded bg-[#1e1e22] text-slate-400 hover:text-white transition-colors font-bold" title="굵게">B</button>
                  <button type="button" onclick="insertMd('- ')" class="text-xs px-2 py-1 rounded bg-[#1e1e22] text-slate-400 hover:text-white transition-colors" title="목록">•</button>
                  <button type="button" onclick="insertMd('> ')" class="text-xs px-2 py-1 rounded bg-[#1e1e22] text-slate-400 hover:text-white transition-colors" title="인용">❝</button>
                  <button type="button" onclick="insertMd('```\n', '\n```')" class="text-xs px-2 py-1 rounded bg-[#1e1e22] text-slate-400 hover:text-white transition-colors font-mono" title="코드">{}</button>
                </div>
                <span class="text-[#2a2a30]">|</span>
                <button type="button" id="toggle-preview" onclick="toggleBodyPreview()" class="text-xs px-3 py-1 rounded-full border border-[#2a2a30] text-slate-400 hover:text-white hover:border-indigo-500 transition-all flex items-center gap-1">
                  <span class="material-symbols-outlined text-xs">visibility</span>
                  미리보기
                </button>
              </div>
            </div>
            <div class="body-editor-split">
              <textarea id="body-editor" rows="16" class="w-full px-4 py-3 bg-[#1e1e22] border border-[#2a2a30] rounded-lg text-sm text-white focus:outline-none focus:border-indigo-500 font-mono leading-relaxed resize-y" placeholder="마크다운으로 본문을 작성하세요..."></textarea>
              <div id="body-preview" class="hidden w-full px-5 py-4 bg-[#0c0c0e] border border-[#2a2a30] rounded-lg text-sm text-white overflow-y-auto prose prose-sm prose-invert max-w-none body-preview-panel"></div>
            </div>
          </div>
          <div class="flex gap-3 mt-6 pt-4 border-t border-[#2a2a30]">
            <button id="save-btn" onclick="saveFile()" class="flex-1 bg-indigo-500 text-white font-bold py-3 rounded-lg text-sm hover:bg-indigo-400 hover:shadow-lg hover:shadow-indigo-500/20 transition-all">저장</button>
            <button onclick="closeEditor()" class="px-6 py-3 border border-[#2a2a30] rounded-lg text-sm text-slate-400 hover:text-white hover:border-slate-500 transition-colors">취소</button>
          </div>
          <div id="save-status" class="hidden mt-3 p-3 rounded-lg text-sm text-center"></div>
          <div class="mt-4 pt-4 border-t border-[#2a2a30]">
            <button id="delete-btn" onclick="deleteFile()" class="w-full flex items-center justify-center gap-1.5 py-2.5 rounded-lg text-sm text-red-400 hover:text-white hover:bg-red-600 border border-red-900/50 hover:border-red-600 transition-all">
              <span class="material-symbols-outlined text-base">delete</span>
              파일 삭제
            </button>
          </div>
        </div>
      </div>

      <!-- Create Modal -->
      <div id="create-modal" class="fixed inset-0 z-50 hidden">
        <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="closeCreateModal()"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-md bg-[#141418] border border-[#2a2a30] rounded-2xl shadow-2xl shadow-black/50 p-6 md:p-8">
          <div class="flex items-center justify-between mb-6">
            <h2 class="font-headline text-lg font-bold text-white">새 파일 만들기</h2>
            <button onclick="closeCreateModal()" class="text-slate-500 hover:text-white">
              <span class="material-symbols-outlined">close</span>
            </button>
          </div>
          <div class="space-y-4">
            <div>
              <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1.5">파일명 (.md 자동 추가)</label>
              <input id="create-filename" type="text" placeholder="예: Week_04_분석" class="w-full px-3 py-2.5 bg-[#1e1e22] border border-[#2a2a30] rounded-lg text-sm text-white focus:outline-none focus:border-indigo-500" />
            </div>
            <div id="create-fields" class="space-y-4"></div>
          </div>
          <div class="flex gap-3 mt-6 pt-4 border-t border-[#2a2a30]">
            <button id="create-save-btn" onclick="createFile()" class="flex-1 bg-indigo-500 text-white font-bold py-3 rounded-lg text-sm hover:bg-indigo-400 hover:shadow-lg hover:shadow-indigo-500/20 transition-all">생성</button>
            <button onclick="closeCreateModal()" class="px-6 py-3 border border-[#2a2a30] rounded-lg text-sm text-slate-400 hover:text-white hover:border-slate-500 transition-colors">취소</button>
          </div>
          <div id="create-status" class="hidden mt-3 p-3 rounded-lg text-sm text-center"></div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .ms-chip {
      background: transparent;
      color: #71717a;
      border-color: #2a2a30;
    }
    .ms-chip:hover { border-color: #818cf8; color: #fff; }
    .ms-chip.active { background: #818cf8; color: #fff; border-color: #818cf8; font-weight: 700; }

    .managed-tag-chip {
      padding: 4px 8px 4px 12px;
      border-radius: 9999px;
      font-size: 12px;
      font-weight: 500;
      border: 1px solid #2a2a30;
      background: transparent;
      color: #71717a;
      cursor: pointer;
      transition: all 0.15s;
    }
    .managed-tag-chip:hover { border-color: #818cf8; color: #fff; }
    .managed-tag-chip.active { background: #818cf8; color: #fff; border-color: #818cf8; font-weight: 700; }
    .managed-tag-chip .remove-managed-tag {
      display: none;
      width: 16px; height: 16px;
      border-radius: 50%;
      font-size: 13px; line-height: 16px;
      text-align: center;
      background: rgba(255,255,255,0.15);
      color: inherit;
      border: none;
      cursor: pointer;
      padding: 0;
      transition: background 0.15s;
    }
    .managed-tag-chip:hover .remove-managed-tag { display: inline-flex; align-items: center; justify-content: center; }
    .managed-tag-chip .remove-managed-tag:hover { background: #ef4444; color: #fff; }

    .tab-btn {
      background: transparent;
      color: #71717a;
      border: 1px solid #2a2a30;
    }
    .tab-btn:hover { border-color: #818cf8; color: #fff; }
    .tab-btn.active { background: #818cf8; color: #fff; font-weight: 700; border-color: #818cf8; }

    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-4px); }
      75% { transform: translateX(4px); }
    }

    #body-editor {
      min-height: 300px;
      tab-size: 2;
    }
    .body-editor-split {
      display: flex;
      gap: 0.75rem;
    }
    .body-editor-split.split-mode {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
    .body-editor-split.split-mode #body-editor {
      min-height: 400px;
    }
    .body-preview-panel {
      min-height: 400px;
      max-height: 500px;
    }
    .body-preview-panel h2 { font-size: 1.3em; font-weight: 700; margin-top: 1.2em; margin-bottom: 0.4em; border-bottom: 1px solid var(--border, #e5e7eb); padding-bottom: 0.3em; }
    .body-preview-panel h3 { font-size: 1.1em; font-weight: 700; margin-top: 1em; margin-bottom: 0.3em; }
    .body-preview-panel ul, .body-preview-panel ol { padding-left: 1.5em; margin: 0.5em 0; }
    .body-preview-panel li { margin: 0.2em 0; }
    .body-preview-panel blockquote { border-left: 3px solid #818cf8; padding-left: 1em; margin: 0.8em 0; color: #71717a; }
    .body-preview-panel code { background: rgba(129,140,248,0.1); padding: 0.15em 0.4em; border-radius: 4px; font-size: 0.85em; }
    .body-preview-panel pre { background: #1e1e20; padding: 1em; border-radius: 8px; overflow-x: auto; margin: 0.8em 0; }
    .body-preview-panel pre code { background: none; padding: 0; }
    .body-preview-panel strong { color: inherit; font-weight: 700; }
    .body-preview-panel p { margin: 0.5em 0; }
    #toggle-preview.active { background: #818cf8; color: #fff; border-color: #818cf8; font-weight: 700; }
    @media (max-width: 768px) {
      .body-editor-split.split-mode { grid-template-columns: 1fr; }
    }
  </style>

  <script is:inline define:vars={{ collections }}>
    const OWNER = 'selfishclub';
    const REPO = 'aaa-admin';
    let currentCollection = 'gallery';
    let currentFile = null;
    let currentSha = null;
    let currentBody = '';

    function getToken() { return localStorage.getItem('gh_token') || ''; }

    async function api(endpoint, options = {}) {
      const res = await fetch(`https://api.github.com/repos/${OWNER}/${REPO}/${endpoint}`, {
        ...options,
        headers: {
          'Authorization': `token ${getToken()}`,
          'Accept': 'application/vnd.github.v3+json',
          ...(options.headers || {}),
          ...(options.body ? { 'Content-Type': 'application/json' } : {}),
        }
      });
      if (!res.ok) throw new Error(`GitHub API ${res.status}`);
      return res.json();
    }

    function parseFrontmatter(content) {
      const match = content.match(/^---\n([\s\S]*?)\n---\n?([\s\S]*)$/);
      if (!match) return { data: {}, body: content };
      const data = {};
      const lines = match[1].split('\n');
      let currentKey = null;
      let currentList = null;

      for (const line of lines) {
        if (line.match(/^\s+-\s+/) && currentKey) {
          const val = line.replace(/^\s+-\s+/, '').trim();
          if (!currentList) currentList = [];
          currentList.push(val);
          data[currentKey] = currentList;
          continue;
        }
        const m = line.match(/^([a-zA-Z_]\w*):\s*(.*)$/);
        if (m) {
          currentList = null;
          currentKey = m[1];
          let val = m[2].trim();

          if (val === '' || val === '~' || val === 'null') {
            data[currentKey] = '';
            continue;
          }
          if (val.startsWith('[') && val.endsWith(']')) {
            val = val.slice(1, -1).split(',').map(s => s.trim().replace(/^["']|["']$/g, ''));
          } else if (val.startsWith('"') && val.endsWith('"')) {
            val = val.slice(1, -1);
          } else if (!isNaN(val) && val !== '') {
            val = Number(val);
          }
          data[currentKey] = val;
          currentList = null;
        }
      }
      return { data, body: match[2] };
    }

    function buildFrontmatter(data, body) {
      let yaml = '---\n';
      for (const [key, val] of Object.entries(data)) {
        if (val === undefined || val === null || val === '') continue;
        if (Array.isArray(val)) {
          if (val.length === 0) continue;
          yaml += `${key}:\n`;
          for (const item of val) {
            yaml += `  - ${item}\n`;
          }
        } else if (typeof val === 'number') {
          yaml += `${key}: ${val}\n`;
        } else {
          yaml += `${key}: "${val}"\n`;
        }
      }
      yaml += '---\n';
      return yaml + (body || '');
    }

    function safeDecodeUri(str) {
      try { return decodeURIComponent(str); } catch { return str; }
    }

    async function uploadImage(file, uploadPath) {
      const reader = new FileReader();
      return new Promise((resolve, reject) => {
        reader.onload = async () => {
          try {
            const base64 = reader.result.split(',')[1];
            const dataUrl = reader.result;
            const safeName = Date.now() + '_' + file.name.replace(/[^a-zA-Z0-9._-]/g, '_');
            const filePath = `${uploadPath}/${safeName}`;
            await api(`contents/${filePath}`, {
              method: 'PUT',
              body: JSON.stringify({
                message: `admin: 이미지 업로드 ${safeName}`,
                content: base64,
              })
            });
            const result = `/images/${uploadPath.replace('public/images/', '')}/${safeName}`;
            resolve({ url: result, dataUrl });
          } catch (e) { reject(e); }
        };
        reader.onerror = reject;
        reader.readAsDataURL(file);
      });
    }

    // Managed tags helpers
    function getManagedTags(storageKey, defaults) {
      const stored = localStorage.getItem(storageKey);
      if (stored) {
        try { return JSON.parse(stored); } catch { /* fall through */ }
      }
      return [...defaults];
    }
    function saveManagedTags(storageKey, tags) {
      localStorage.setItem(storageKey, JSON.stringify(tags));
    }

    // Collect all existing keywords from insight files for autocomplete
    let allInsightKeywords = [];
    async function loadInsightKeywords() {
      try {
        const files = await api('contents/src/content/insights');
        const mdFiles = files.filter(f => f.name.endsWith('.md'));
        const kwSet = new Set();
        for (const f of mdFiles.slice(0, 30)) {
          try {
            const file = await api(`contents/${f.path}`);
            const decoded = new TextDecoder().decode(Uint8Array.from(atob(file.content.replace(/\n/g, '')), c => c.charCodeAt(0)));
            const { data } = parseFrontmatter(decoded);
            if (data.keywords) {
              const kws = Array.isArray(data.keywords) ? data.keywords : [data.keywords];
              kws.forEach(kw => kwSet.add(kw));
            }
          } catch {}
        }
        allInsightKeywords = [...kwSet];
        saveManagedTags('insight_keywords', allInsightKeywords);
      } catch {}
    }

    function renderFieldHtml(field, val) {
      if (field.type === 'managed-tags') {
        const managedTags = getManagedTags(field.storageKey, field.defaults || []);
        const selected = Array.isArray(val) ? val : (val ? val.split(',').map(s => s.trim()).filter(Boolean) : []);
        const maxTags = field.maxTags || 0;
        const maxHint = maxTags > 0 ? ` (최대 ${maxTags}개)` : '';
        let activeCount = 0;
        const chips = managedTags.map(tag => {
          const isSelected = selected.includes(tag);
          const active = isSelected && (maxTags <= 0 || activeCount < maxTags);
          if (active) activeCount++;
          return `<span class="managed-tag-chip inline-flex items-center gap-1 ${active ? 'active' : ''}" data-option="${tag}">
            <span class="tag-label">${tag}</span>
            <button type="button" class="remove-managed-tag" data-tag="${tag}" title="태그 삭제">×</button>
          </span>`;
        }).join('');

        return `
          <div>
            <label class="block text-xs font-bold text-slate-600 dark:text-gray-400 uppercase tracking-wider mb-1.5">${field.label}${maxHint}</label>
            <div data-key="${field.key}" data-type="managed-tags" data-storage-key="${field.storageKey}" data-max-tags="${maxTags}" class="admin-input">
              <div class="flex flex-wrap gap-2 p-2.5 bg-[#1e1e22] border border-[#2a2a30] rounded-lg min-h-[42px] managed-chips">
                ${chips}
              </div>
              <div class="flex gap-2 mt-2">
                <input type="text" placeholder="새 태그 입력 후 Enter..." class="new-tag-input flex-1 px-3 py-1.5 bg-[#1e1e22] border border-[#2a2a30] rounded-lg text-xs text-white focus:outline-none focus:border-indigo-500" />
                <button type="button" class="add-tag-btn px-3 py-1.5 bg-black dark:bg-white text-white dark:text-black rounded-lg text-xs font-bold hover:shadow-md transition-all">추가</button>
              </div>
            </div>
          </div>`;
      }
      if (field.type === 'image') {
        const preview = val ? `<img src="${val}" class="w-full h-24 object-cover rounded-lg border border-slate-200 dark:border-[#353437]" />` : '';
        return `
          <div>
            <label class="block text-xs font-bold text-slate-600 dark:text-gray-400 uppercase tracking-wider mb-1.5">${field.label}</label>
            <p class="text-[10px] text-slate-400 dark:text-gray-500 mb-2">권장: <strong>${field.sizeHint || ''}</strong></p>
            <div data-key="${field.key}" data-type="image" data-upload-path="${field.uploadPath || ''}" class="admin-input">
              <div class="img-preview mb-2">${preview}</div>
              <input type="text" value="${val || ''}" placeholder="이미지 URL 붙여넣기" class="img-url w-full px-3 py-2 bg-[#1e1e22] border border-[#2a2a30] rounded-lg text-sm text-white focus:outline-none focus:border-indigo-500 mb-2" />
              <label class="flex items-center justify-center gap-2 px-3 py-2.5 bg-[#1e1e22] border border-dashed border-[#2a2a30] rounded-lg cursor-pointer hover:border-indigo-500 transition-colors">
                <span class="material-symbols-outlined text-sm text-slate-400">upload</span>
                <span class="text-xs text-slate-500 dark:text-gray-400">파일 선택 또는 드래그</span>
                <input type="file" accept="image/*" class="img-file hidden" />
              </label>
            </div>
          </div>`;
      }
      if (field.type === 'multiselect') {
        const selected = Array.isArray(val) ? val : (val ? [val] : []);
        const chips = (field.options || []).map(o => {
          const active = selected.includes(o);
          return `<button type="button" data-option="${o}" class="ms-chip ${active ? 'active' : ''} px-3 py-1.5 rounded-full text-xs font-medium border transition-all cursor-pointer">${o}</button>`;
        }).join('');
        return `
          <div>
            <label class="block text-xs font-bold text-slate-600 dark:text-gray-400 uppercase tracking-wider mb-1.5">${field.label}</label>
            <div data-key="${field.key}" data-type="multiselect" class="admin-input flex flex-wrap gap-2 p-2.5 bg-[#1e1e22] border border-[#2a2a30] rounded-lg min-h-[42px]">
              ${chips}
            </div>
          </div>`;
      }
      if (field.type === 'select') {
        const opts = (field.options || []).map(o =>
          `<option value="${o}" ${val === o ? 'selected' : ''}>${o}</option>`
        ).join('');
        return `
          <div>
            <label class="block text-xs font-bold text-slate-600 dark:text-gray-400 uppercase tracking-wider mb-1.5">${field.label}</label>
            <select data-key="${field.key}" class="admin-input w-full px-3 py-2.5 bg-[#1e1e22] border border-[#2a2a30] rounded-lg text-sm text-white focus:outline-none focus:border-indigo-500">
              <option value="">선택...</option>
              ${opts}
            </select>
          </div>`;
      }
      if (field.type === 'textarea') {
        return `
          <div>
            <label class="block text-xs font-bold text-slate-600 dark:text-gray-400 uppercase tracking-wider mb-1.5">${field.label}</label>
            <textarea data-key="${field.key}" rows="3" class="admin-input w-full px-3 py-2.5 bg-[#1e1e22] border border-[#2a2a30] rounded-lg text-sm text-white focus:outline-none focus:border-indigo-500 resize-none">${val}</textarea>
          </div>`;
      }
      return `
        <div>
          <label class="block text-xs font-bold text-slate-600 dark:text-gray-400 uppercase tracking-wider mb-1.5">${field.label}</label>
          <input data-key="${field.key}" type="${field.type === 'number' ? 'number' : 'text'}" value="${val}" placeholder="${field.placeholder || ''}"
            class="admin-input w-full px-3 py-2.5 bg-[#1e1e22] border border-[#2a2a30] rounded-lg text-sm text-white focus:outline-none focus:border-indigo-500" />
        </div>`;
    }

    function collectFieldData(selector) {
      const col = collections[currentCollection];
      const data = {};
      document.querySelectorAll(selector).forEach(input => {
        const key = input.dataset.key;
        if (input.dataset.type === 'managed-tags') {
          const maxTags = parseInt(input.dataset.maxTags) || 0;
          let selected = Array.from(input.querySelectorAll('.managed-chips .managed-tag-chip.active')).map(c => c.dataset.option);
          if (maxTags > 0) selected = selected.slice(0, maxTags);
          if (selected.length > 0) data[key] = selected;
          return;
        }
        if (input.dataset.type === 'multiselect') {
          const selected = Array.from(input.querySelectorAll('.ms-chip.active')).map(c => c.dataset.option);
          if (selected.length > 0) data[key] = selected;
          return;
        }
        if (input.dataset.type === 'image') {
          const val = input.querySelector('.img-url')?.value.trim();
          if (val) data[key] = val;
          return;
        }
        let val = input.value.trim();
        const field = col.fields.find(f => f.key === key);
        if (field?.type === 'number' && val) val = Number(val);
        if (field?.type === 'tags' && val) val = val.split(',').map(s => s.trim()).filter(Boolean);
        if (val !== '' && val !== null) data[key] = val;
      });
      return data;
    }

    // Multiselect chip toggle (legacy ms-chip)
    document.addEventListener('click', (e) => {
      if (e.target.classList.contains('ms-chip')) {
        e.target.classList.toggle('active');
      }
    });

    // Managed tag chip: toggle select (click on label or chip itself)
    document.addEventListener('click', (e) => {
      const chip = e.target.closest('.managed-tag-chip');
      if (!chip) return;
      // Ignore if clicking the remove button
      if (e.target.closest('.remove-managed-tag')) return;

      const wrapper = chip.closest('[data-type="managed-tags"]');
      const maxTags = parseInt(wrapper?.dataset.maxTags) || 0;
      if (!chip.classList.contains('active') && maxTags > 0) {
        const activeCount = wrapper.querySelectorAll('.managed-tag-chip.active').length;
        if (activeCount >= maxTags) {
          chip.style.animation = 'shake 0.3s ease';
          setTimeout(() => chip.style.animation = '', 300);
          return;
        }
      }
      chip.classList.toggle('active');
    });

    // Managed tag chip: remove tag (X button)
    document.addEventListener('click', (e) => {
      if (!e.target.closest('.remove-managed-tag')) return;
      const btn = e.target.closest('.remove-managed-tag');
      const tag = btn.dataset.tag;
      const wrapper = btn.closest('[data-type="managed-tags"]');
      const storageKey = wrapper.dataset.storageKey;
      if (!confirm(`"${tag}" 태그를 삭제하시겠습니까?`)) return;
      const tags = getManagedTags(storageKey, []);
      const idx = tags.indexOf(tag);
      if (idx > -1) {
        tags.splice(idx, 1);
        saveManagedTags(storageKey, tags);
      }
      btn.closest('.managed-tag-chip').remove();
    });

    // Managed tags: add new tag
    document.addEventListener('click', (e) => {
      if (e.target.classList.contains('add-tag-btn')) {
        const wrapper = e.target.closest('[data-type="managed-tags"]');
        const input = wrapper.querySelector('.new-tag-input');
        const tag = input.value.trim();
        if (!tag) return;
        const storageKey = wrapper.dataset.storageKey;
        const tags = getManagedTags(storageKey, []);
        if (tags.includes(tag)) { input.value = ''; return; }
        tags.push(tag);
        saveManagedTags(storageKey, tags);
        const chipsEl = wrapper.querySelector('.managed-chips');
        const chipHtml = `<span class="managed-tag-chip inline-flex items-center gap-1 active" data-option="${tag}">
          <span class="tag-label">${tag}</span>
          <button type="button" class="remove-managed-tag" data-tag="${tag}" title="태그 삭제">×</button>
        </span>`;
        chipsEl.insertAdjacentHTML('beforeend', chipHtml);
        input.value = '';
      }
    });

    // Managed tags: enter key to add (skip during IME composition)
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && e.target.classList.contains('new-tag-input')) {
        if (e.isComposing || e.keyCode === 229) return;
        e.preventDefault();
        const wrapper = e.target.closest('[data-type="managed-tags"]');
        wrapper.querySelector('.add-tag-btn').click();
      }
    });

    // Load marked.js for live preview
    const markedScript = document.createElement('script');
    markedScript.src = 'https://cdn.jsdelivr.net/npm/marked/marked.min.js';
    document.head.appendChild(markedScript);

    // Toggle preview panel
    let previewActive = false;
    window.toggleBodyPreview = function() {
      const editor = document.getElementById('body-editor');
      const preview = document.getElementById('body-preview');
      const split = document.querySelector('.body-editor-split');
      const btn = document.getElementById('toggle-preview');
      previewActive = !previewActive;

      if (previewActive) {
        preview.classList.remove('hidden');
        split.classList.add('split-mode');
        btn.classList.add('active');
        updatePreview();
      } else {
        preview.classList.add('hidden');
        split.classList.remove('split-mode');
        btn.classList.remove('active');
      }
    };

    function updatePreview() {
      const editor = document.getElementById('body-editor');
      const preview = document.getElementById('body-preview');
      if (!editor || !preview || preview.classList.contains('hidden')) return;
      if (typeof marked !== 'undefined' && marked.parse) {
        preview.innerHTML = marked.parse(editor.value || '');
      } else {
        preview.innerHTML = '<p style="color:#71717a;font-size:0.8rem;">marked.js 로딩 중...</p>';
        setTimeout(updatePreview, 300);
      }
    }

    // Live update on typing
    document.addEventListener('input', (e) => {
      if (e.target.id === 'body-editor' && previewActive) {
        updatePreview();
      }
    });

    // Body editor: insert markdown
    window.insertMd = function(prefix, suffix) {
      const editor = document.getElementById('body-editor');
      if (!editor) return;
      const start = editor.selectionStart;
      const end = editor.selectionEnd;
      const text = editor.value;
      const selected = text.substring(start, end);
      const replacement = suffix ? prefix + (selected || '텍스트') + suffix : prefix + (selected || '');
      editor.value = text.substring(0, start) + replacement + text.substring(end);
      editor.focus();
      const cursorPos = start + replacement.length;
      editor.setSelectionRange(cursorPos, cursorPos);
    };

    // Image field: file upload + URL preview
    document.addEventListener('change', async (e) => {
      if (e.target.classList.contains('img-file')) {
        const file = e.target.files[0];
        if (!file) return;
        const wrapper = e.target.closest('[data-type="image"]');
        const urlInput = wrapper.querySelector('.img-url');
        const previewEl = wrapper.querySelector('.img-preview');
        const uploadPath = wrapper.dataset.uploadPath;
        previewEl.innerHTML = '<p class="text-xs text-slate-400 animate-pulse">업로드 중...</p>';
        try {
          const result = await uploadImage(file, uploadPath);
          urlInput.value = result.url;
          previewEl.innerHTML = `<img src="${result.dataUrl}" class="w-full h-24 object-cover rounded-lg border border-slate-200 dark:border-[#353437]" />`;
        } catch (err) {
          previewEl.innerHTML = `<p class="text-xs text-red-500">업로드 실패: ${err.message}</p>`;
        }
      }
    });

    document.addEventListener('input', (e) => {
      if (e.target.classList.contains('img-url')) {
        const wrapper = e.target.closest('[data-type="image"]');
        const previewEl = wrapper.querySelector('.img-preview');
        const val = e.target.value.trim();
        if (val && (val.startsWith('http') || val.startsWith('/'))) {
          previewEl.innerHTML = `<img src="${val}" class="w-full h-24 object-cover rounded-lg border border-slate-200 dark:border-[#353437]" onerror="this.parentElement.innerHTML=''" />`;
        } else {
          previewEl.innerHTML = '';
        }
      }
    });

    // Token setup
    document.getElementById('token-save').addEventListener('click', () => {
      const token = document.getElementById('token-input').value.trim();
      if (!token) return;
      localStorage.setItem('gh_token', token);
      document.getElementById('token-input').value = '';
      initAdmin();
    });

    // Tab switching
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentCollection = btn.dataset.collection;
        loadFiles();
      });
    });

    async function loadFiles() {
      const listEl = document.getElementById('file-list');
      const loadingEl = document.getElementById('loading');
      listEl.classList.add('hidden');
      loadingEl.classList.remove('hidden');

      try {
        const col = collections[currentCollection];
        const files = await api(`contents/${col.path}`);
        const mdFiles = files.filter(f => f.name.endsWith('.md'));

        listEl.innerHTML = mdFiles.map(f => `
          <div class="file-item flex items-center gap-4 px-5 py-3.5 rounded-lg hover:bg-[#141418] transition-all cursor-pointer border border-transparent hover:border-indigo-500/30 group"
               data-path="${f.path}" data-sha="${f.sha}">
            <span class="material-symbols-outlined text-slate-500 group-hover:text-indigo-400 text-lg">description</span>
            <span class="flex-1 text-sm font-medium text-white group-hover:text-indigo-300 truncate">${safeDecodeUri(f.name.replace('.md', ''))}</span>
            <span class="material-symbols-outlined text-slate-300 text-sm">edit</span>
          </div>
        `).join('');

        listEl.querySelectorAll('.file-item').forEach(item => {
          item.addEventListener('click', () => openEditor(item.dataset.path));
        });

        loadingEl.classList.add('hidden');
        listEl.classList.remove('hidden');
      } catch (e) {
        loadingEl.classList.add('hidden');
        listEl.innerHTML = '<p class="text-red-500 text-sm text-center py-8">파일 로드 실패: ' + e.message + '</p>';
        listEl.classList.remove('hidden');
      }
    }

    async function openEditor(path) {
      const col = collections[currentCollection];
      const file = await api(`contents/${path}`);
      const decoded = new TextDecoder().decode(Uint8Array.from(atob(file.content.replace(/\n/g, '')), c => c.charCodeAt(0)));
      const { data, body } = parseFrontmatter(decoded);
      currentFile = path;
      currentSha = file.sha;
      currentBody = body;

      const fileName = path.split('/').pop().replace('.md', '');
      document.getElementById('edit-title').textContent = safeDecodeUri(fileName);

      const fieldsEl = document.getElementById('edit-fields');
      fieldsEl.innerHTML = col.fields.map(field => {
        let val = data[field.key] || '';
        if ((field.type === 'tags' || field.key === 'keywords') && Array.isArray(val)) {
          val = val.join(', ');
        }
        return renderFieldHtml(field, val);
      }).join('');

      // Body editor for analysis/proposals
      const bodyWrap = document.getElementById('body-editor-wrap');
      const bodyEditor = document.getElementById('body-editor');
      const modalInner = document.getElementById('edit-modal-inner');
      if (col.hasBodyEditor) {
        bodyEditor.value = body || '';
        bodyWrap.classList.remove('hidden');
        modalInner.classList.remove('max-w-lg');
        modalInner.classList.add('max-w-3xl');
      } else {
        bodyWrap.classList.add('hidden');
        modalInner.classList.remove('max-w-3xl');
        modalInner.classList.add('max-w-lg');
      }

      // Load insight keywords for autocomplete if editing insights
      if (currentCollection === 'insights' && allInsightKeywords.length === 0) {
        loadInsightKeywords();
      }

      document.getElementById('save-status').classList.add('hidden');
      document.getElementById('edit-modal').classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    window.closeEditor = function() {
      document.getElementById('edit-modal').classList.add('hidden');
      document.body.style.overflow = '';
    };

    window.saveFile = async function() {
      const btn = document.getElementById('save-btn');
      const statusEl = document.getElementById('save-status');
      btn.textContent = '저장 중...';
      btn.disabled = true;

      try {
        const data = collectFieldData('#edit-fields .admin-input');
        const col = collections[currentCollection];
        const bodyContent = col.hasBodyEditor ? document.getElementById('body-editor').value : currentBody;
        const newContent = buildFrontmatter(data, bodyContent);
        const encoded = btoa(unescape(encodeURIComponent(newContent)));

        await api(`contents/${currentFile}`, {
          method: 'PUT',
          body: JSON.stringify({
            message: `admin: ${currentFile.split('/').pop()} frontmatter 수정`,
            content: encoded,
            sha: currentSha,
          })
        });

        statusEl.className = 'mt-3 p-3 rounded-lg text-sm text-center bg-indigo-500/10 text-indigo-300 border border-indigo-500/30';
        statusEl.textContent = '✓ 저장 완료! Vercel이 자동 재배포합니다.';
        statusEl.classList.remove('hidden');
        btn.textContent = '저장';
        btn.disabled = false;

        setTimeout(() => { closeEditor(); loadFiles(); }, 1500);
      } catch (e) {
        statusEl.className = 'mt-3 p-3 rounded-lg text-sm text-center bg-red-50 text-red-500 border border-red-200';
        statusEl.textContent = '저장 실패: ' + e.message;
        statusEl.classList.remove('hidden');
        btn.textContent = '저장';
        btn.disabled = false;
      }
    };

    window.deleteFile = async function() {
      if (!currentFile) return;
      const fileName = currentFile.split('/').pop();
      if (!confirm(`"${safeDecodeUri(fileName)}" 파일을 삭제하시겠습니까?\n이 작업은 되돌릴 수 없습니다.`)) return;

      const btn = document.getElementById('delete-btn');
      const statusEl = document.getElementById('save-status');
      btn.textContent = '삭제 중...';
      btn.disabled = true;

      try {
        await api(`contents/${currentFile}`, {
          method: 'DELETE',
          body: JSON.stringify({
            message: `admin: ${fileName} 삭제`,
            sha: currentSha,
          })
        });

        statusEl.className = 'mt-3 p-3 rounded-lg text-sm text-center bg-red-50 dark:bg-red-900/20 text-red-500 border border-red-200 dark:border-red-900';
        statusEl.textContent = '✓ 삭제 완료.';
        statusEl.classList.remove('hidden');
        btn.textContent = '파일 삭제';
        btn.disabled = false;

        setTimeout(() => { closeEditor(); loadFiles(); }, 1200);
      } catch (e) {
        statusEl.className = 'mt-3 p-3 rounded-lg text-sm text-center bg-red-50 text-red-500 border border-red-200';
        statusEl.textContent = '삭제 실패: ' + e.message;
        statusEl.classList.remove('hidden');
        btn.textContent = '파일 삭제';
        btn.disabled = false;
      }
    };

    window.openCreateModal = function() {
      const col = collections[currentCollection];
      document.getElementById('create-filename').value = '';

      const fieldsEl = document.getElementById('create-fields');
      fieldsEl.innerHTML = col.fields.map(field => renderFieldHtml(field, '')).join('');

      // Add body editor to create modal if collection supports it
      if (col.hasBodyEditor) {
        fieldsEl.innerHTML += `
          <div class="pt-4 border-t border-slate-100 dark:border-[#353437]">
            <label class="block text-xs font-bold text-slate-600 dark:text-gray-400 uppercase tracking-wider mb-2">본문 (마크다운)</label>
            <textarea id="create-body-editor" rows="12" class="w-full px-4 py-3 bg-[#1e1e22] border border-[#2a2a30] rounded-lg text-sm text-white focus:outline-none focus:border-indigo-500 font-mono leading-relaxed resize-y" placeholder="마크다운으로 본문을 작성하세요..."></textarea>
          </div>`;
      }

      document.getElementById('create-status').classList.add('hidden');
      document.getElementById('create-modal').classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      document.getElementById('create-filename').focus();
    };

    window.closeCreateModal = function() {
      document.getElementById('create-modal').classList.add('hidden');
      document.body.style.overflow = '';
    };

    window.createFile = async function() {
      const filename = document.getElementById('create-filename').value.trim();
      const statusEl = document.getElementById('create-status');
      const btn = document.getElementById('create-save-btn');

      if (!filename) {
        statusEl.className = 'mt-3 p-3 rounded-lg text-sm text-center bg-red-50 text-red-500 border border-red-200';
        statusEl.textContent = '파일명을 입력해주세요.';
        statusEl.classList.remove('hidden');
        return;
      }

      btn.textContent = '생성 중...';
      btn.disabled = true;

      try {
        const col = collections[currentCollection];
        const data = collectFieldData('#create-fields .admin-input');
        const createBodyEditor = document.getElementById('create-body-editor');
        const bodyText = (col.hasBodyEditor && createBodyEditor) ? createBodyEditor.value : '\n';
        const content = buildFrontmatter(data, bodyText || '\n');
        const encoded = btoa(unescape(encodeURIComponent(content)));
        const filePath = `${col.path}/${filename}.md`;

        await api(`contents/${filePath}`, {
          method: 'PUT',
          body: JSON.stringify({
            message: `admin: ${filename}.md 생성`,
            content: encoded,
          })
        });

        statusEl.className = 'mt-3 p-3 rounded-lg text-sm text-center bg-indigo-500/10 text-indigo-300 border border-indigo-500/30';
        statusEl.textContent = '✓ 생성 완료!';
        statusEl.classList.remove('hidden');
        btn.textContent = '생성';
        btn.disabled = false;

        setTimeout(() => { closeCreateModal(); loadFiles(); }, 1200);
      } catch (e) {
        statusEl.className = 'mt-3 p-3 rounded-lg text-sm text-center bg-red-50 text-red-500 border border-red-200';
        statusEl.textContent = '생성 실패: ' + e.message;
        statusEl.classList.remove('hidden');
        btn.textContent = '생성';
        btn.disabled = false;
      }
    };

    function initAdmin() {
      if (getToken()) {
        document.getElementById('no-token').classList.add('hidden');
        document.getElementById('token-input').style.display = 'none';
        document.getElementById('token-save').style.display = 'none';
        document.getElementById('token-status').classList.remove('hidden');
        document.getElementById('token-reset').classList.remove('hidden');
        document.getElementById('create-btn').classList.remove('hidden');
        document.getElementById('create-btn').classList.add('flex');
        loadFiles();
      }
    }

    document.addEventListener('DOMContentLoaded', initAdmin);
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') {
        closeEditor();
        closeCreateModal();
      }
    });
  </script>
  </div><!-- /admin-shell -->
</Layout>
