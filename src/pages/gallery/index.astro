---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';
const gallery = await getCollection('gallery');
const projects = gallery.filter(g => g.data.name);
---
<Layout title="갤러리 - AAA 아카이브">
  <!-- Hero Banner -->
  <section class="pt-20 md:pt-24" style="background: linear-gradient(135deg, rgba(251,232,48,0.08) 0%, rgba(251,232,48,0.15) 40%, rgba(200,240,200,0.1) 100%);">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 pt-8 md:pt-10 pb-8 md:pb-10">
      <h1 class="font-headline text-2xl md:text-3xl font-extrabold tracking-tight text-black dark:text-white mb-2">결과물 갤러리</h1>
      <p class="text-sm md:text-base text-slate-600 dark:text-gray-400 mb-4">실제로 <strong class="text-black dark:text-white">만들고 배포</strong>한 프로젝트들을 모아봅니다.</p>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1 text-xs font-medium border border-slate-200 dark:border-[#353437] rounded-full text-slate-600 dark:text-gray-400 bg-white/60 dark:bg-[#1b1b1d]/60">#결과물</span>
        <span class="px-3 py-1 text-xs font-medium border border-slate-200 dark:border-[#353437] rounded-full text-slate-600 dark:text-gray-400 bg-white/60 dark:bg-[#1b1b1d]/60">#배포</span>
        <span class="px-3 py-1 text-xs font-medium border border-slate-200 dark:border-[#353437] rounded-full text-slate-600 dark:text-gray-400 bg-white/60 dark:bg-[#1b1b1d]/60">#프로젝트</span>
      </div>
    </div>
  </section>

  <section class="pb-24 px-6 md:px-16 max-w-[1440px] mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects.map(project => (
        <a href={project.data.link || '#'} target="_blank" class="group bg-surface-low rounded-xl overflow-hidden hover:bg-surface-high transition-all duration-300 block">
          <div class="h-48 bg-gradient-to-br from-surface-high to-surface-container flex items-center justify-center">
            <span class="text-5xl">{project.data.thumbnail || '&#x1F680;'}</span>
          </div>
          <div class="p-6">
            <h3 class="font-headline text-lg font-bold mb-2 group-hover:text-primary-fixed transition-colors">{project.data.name}</h3>
            <p class="text-on-surface/40 text-sm">{project.data.maker} &middot; Week {project.data.week || '?'}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
