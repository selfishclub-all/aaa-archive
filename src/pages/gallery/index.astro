---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';
const gallery = await getCollection('gallery');
const projects = gallery.filter(g => g.data.name);
const base = import.meta.env.BASE_URL;
---
<Layout title="갤러리 - AAA TEAM by Selfish Club">
  <!-- Hero Banner -->
  <section class="pt-14 md:pt-16" style="background: linear-gradient(135deg, rgba(251,232,48,0.08) 0%, rgba(251,232,48,0.15) 40%, rgba(200,240,200,0.1) 100%);">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 pt-8 md:pt-10 pb-8 md:pb-10">
      <h1 class="font-headline text-2xl md:text-3xl font-extrabold tracking-tight text-black dark:text-white mb-2">결과물 갤러리</h1>
      <p class="text-sm md:text-base text-slate-600 dark:text-gray-400 mb-4">실제로 <strong class="text-black dark:text-white">만들고 배포</strong>한 프로젝트들을 모아봅니다.</p>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1 text-xs font-medium border border-slate-200 dark:border-[#353437] rounded-full text-slate-600 dark:text-gray-400 bg-white/60 dark:bg-[#1b1b1d]/60">#결과물</span>
        <span class="px-3 py-1 text-xs font-medium border border-slate-200 dark:border-[#353437] rounded-full text-slate-600 dark:text-gray-400 bg-white/60 dark:bg-[#1b1b1d]/60">#배포</span>
        <span class="px-3 py-1 text-xs font-medium border border-slate-200 dark:border-[#353437] rounded-full text-slate-600 dark:text-gray-400 bg-white/60 dark:bg-[#1b1b1d]/60">#프로젝트</span>
      </div>
    </div>
  </section>

  <!-- Projects Grid -->
  <section class="bg-white dark:bg-[#131315]">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 pt-10 md:pt-12 pb-24">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {projects.map((project, idx) => (
          <a
            href={project.data.link || '#'}
            target="_blank"
            class="group block rounded-xl border border-slate-100 dark:border-[#353437] hover:border-[#FBE830]/50 bg-slate-50/50 dark:bg-[#1b1b1d] hover:shadow-lg transition-all duration-300 overflow-hidden"
            style={`animation-delay: ${idx * 50}ms`}
          >
            <div class="h-40 bg-slate-100 dark:bg-[#252527] flex items-center justify-center overflow-hidden">
              {project.data.thumbnail && project.data.thumbnail.startsWith('http') ? (
                <img src={project.data.thumbnail} alt={project.data.name} class="w-full h-full object-cover" />
              ) : project.data.thumbnail && project.data.thumbnail.startsWith('/images/') ? (
                <img src={`https://raw.githubusercontent.com/selfishclub/aaa-admin/main/public${project.data.thumbnail}`} alt={project.data.name} class="w-full h-full object-cover" />
              ) : (
                <span class="text-5xl">{project.data.thumbnail || '\u{1F680}'}</span>
              )}
            </div>
            <div class="p-5">
              <h3 class="font-headline text-base font-bold text-black dark:text-white mb-2 group-hover:text-[#b8960a] dark:group-hover:text-[#FBE830] transition-colors">{project.data.name}</h3>
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <div class="w-5 h-5 bg-slate-200 dark:bg-[#353437] rounded-full flex items-center justify-center">
                    <span class="text-[8px] font-bold text-slate-500 dark:text-gray-400">{(project.data.maker || '?').charAt(0)}</span>
                  </div>
                  <span class="text-xs text-slate-400 dark:text-gray-500">{project.data.maker || '멤버'}</span>
                </div>
                <span class="text-[10px] text-slate-400 dark:text-gray-500 font-medium">Week {project.data.week || '?'}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <style>
    a[style*="animation-delay"] {
      animation: fadeUp 0.4s ease both;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</Layout>
