---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const concepts = await getCollection('concepts');
  return concepts.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---
<Layout title={`${entry.id} - AAA 아카이브`}>
  <article class="py-24 px-6 md:px-16 max-w-[800px] mx-auto prose prose-invert prose-lg">
    <h1 class="font-headline text-4xl font-bold mb-8">{entry.id.replace(/-/g, ' ').replace(/_/g, ' ')}</h1>
    <Content />
  </article>
</Layout>
