---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';
const concepts = await getCollection('concepts');
const base = import.meta.env.BASE_URL;
---
<Layout title="개념 노트 - AAA 아카이브">
  <section class="py-24 px-6 md:px-16 max-w-[1440px] mx-auto">
    <span class="text-primary-fixed font-headline text-xs uppercase tracking-[0.3em] font-bold mb-4 block">Concepts</span>
    <h1 class="font-headline text-4xl md:text-5xl font-bold mb-16">개념 노트</h1>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {concepts.map(concept => (
        <a href={`${base}concepts/${concept.id}/`} class="bg-surface-high p-8 rounded-xl hover:translate-y-[-4px] transition-transform duration-300 block">
          <h3 class="font-headline text-lg font-bold mb-2">{concept.id.replace(/-/g, ' ').replace(/_/g, ' ')}</h3>
        </a>
      ))}
    </div>
  </section>
</Layout>
