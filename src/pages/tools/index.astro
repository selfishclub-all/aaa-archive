---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';
const tools = await getCollection('tools');
const base = import.meta.env.BASE_URL;
const categories = [...new Set(tools.map(t => t.data.category).filter(Boolean))];

const iconMap: Record<string, string> = {
  '자동화': 'architecture',
  '콘텐츠': 'filter_alt',
  '분석': 'hub',
  '생산성': 'analytics',
  '디자인': 'palette',
};
---
<Layout title="도구 모음 - AAA 아카이브">
  <section class="py-24 md:py-32 px-6 md:px-12 bg-white dark:bg-[#131315]">
    <div class="max-w-screen-2xl mx-auto">
      <div class="max-w-2xl mb-12">
        <span class="text-[10px] font-bold tracking-[0.3em] text-slate-400 uppercase mb-4 block">Toolsets</span>
        <h1 class="font-headline text-4xl md:text-5xl font-extrabold text-black dark:text-white tracking-tighter mb-6">Popular Toolsets</h1>
        <div class="h-1 w-20 bg-[#FBE830] mb-6"></div>
        <p class="text-slate-500 dark:text-gray-400 leading-relaxed">멤버들이 실전에서 검증한 도구 모음입니다.</p>
      </div>

      <!-- Category Filter -->
      <div class="flex flex-wrap gap-3 mb-12">
        <button class="filter-btn active font-bold text-sm uppercase tracking-wider px-5 py-2.5 rounded-lg transition-all" data-category="all">
          All
        </button>
        {categories.map(cat => (
          <button class="filter-btn font-bold text-sm uppercase tracking-wider px-5 py-2.5 rounded-lg transition-all flex items-center gap-2" data-category={cat}>
            <span class="material-symbols-outlined text-base" style="font-variation-settings: 'FILL' 1;">{iconMap[cat] || 'handyman'}</span>
            {cat}
          </button>
        ))}
      </div>

      <!-- Tools Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6" id="tools-grid">
        {tools.map(tool => (
          <a href={`${base}tools/${tool.id}/`} class="tool-item p-8 bg-slate-50 dark:bg-[#1b1b1d] border border-transparent hover:border-[#FBE830]/30 transition-all rounded-xl block group" data-category={tool.data.category || '기타'}>
            <div class="w-12 h-12 bg-white dark:bg-[#2a2a2c] flex items-center justify-center rounded-lg shadow-sm mb-6">
              <span class="material-symbols-outlined text-black dark:text-white" style="font-variation-settings: 'FILL' 1;">{iconMap[tool.data.category || ''] || 'handyman'}</span>
            </div>
            <h4 class="font-headline text-lg font-bold text-black dark:text-white mb-3 group-hover:text-[#d4a800] dark:group-hover:text-[#FBE830] transition-colors">{tool.data.name || tool.id}</h4>
            <p class="text-slate-500 dark:text-gray-400 text-xs leading-relaxed mb-4">{tool.data.type || ''}</p>
            <div class="flex items-center gap-3">
              {tool.data.difficulty && (
                <span class="text-[10px] font-bold tracking-widest text-[#d4a800] dark:text-[#FBE830] uppercase">{tool.data.difficulty}</span>
              )}
              {tool.data.category && (
                <span class="text-[10px] font-medium tracking-wider text-slate-400 uppercase">{tool.data.category}</span>
              )}
            </div>
          </a>
        ))}
      </div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden text-center py-16">
        <span class="material-symbols-outlined text-slate-300 dark:text-gray-600 text-5xl block mb-4">search_off</span>
        <p class="text-slate-400 dark:text-gray-500">해당 카테고리의 도구가 없습니다.</p>
      </div>
    </div>
  </section>

  <style>
    .filter-btn {
      background: transparent;
      color: #6b7280;
      border: 1px solid #e2e8f0;
    }
    .filter-btn:hover {
      border-color: #FBE830;
      color: #000;
    }
    .filter-btn.active {
      background: #FBE830;
      color: #000;
      border-color: #FBE830;
    }
    :global(.dark) .filter-btn {
      border-color: #353437;
      color: #9ca3af;
    }
    :global(.dark) .filter-btn:hover {
      border-color: #FBE830;
      color: #fff;
    }
    :global(.dark) .filter-btn.active {
      background: #FBE830;
      color: #000;
      border-color: #FBE830;
    }
    .tool-item.hidden-by-filter {
      display: none;
    }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const buttons = document.querySelectorAll('.filter-btn');
      const items = document.querySelectorAll('.tool-item');
      const emptyState = document.getElementById('empty-state');

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          buttons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');

          const category = btn.getAttribute('data-category');
          let visibleCount = 0;

          items.forEach(item => {
            if (category === 'all' || item.getAttribute('data-category') === category) {
              item.classList.remove('hidden-by-filter');
              visibleCount++;
            } else {
              item.classList.add('hidden-by-filter');
            }
          });

          if (emptyState) {
            emptyState.classList.toggle('hidden', visibleCount > 0);
          }
        });
      });
    });
  </script>
</Layout>
