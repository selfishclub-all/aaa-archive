---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';
const skills = await getCollection('skills');
const base = import.meta.env.BASE_URL;
const categories = [...new Set(skills.map(s => s.data.category).filter(Boolean))];

const catCounts: Record<string, number> = {};
categories.forEach(cat => {
  catCounts[cat] = skills.filter(s => s.data.category === cat).length;
});

const accentColors: Record<string, string> = {
  '자동화': '#FBE830',
  '콘텐츠': '#000',
  '분석': '#94a3b8',
  '생산성': '#34d399',
  '디자인': '#a78bfa',
};

const dotColors: Record<string, string> = {
  '자동화': 'bg-[#FBE830]',
  '콘텐츠': 'bg-black dark:bg-white',
  '분석': 'bg-slate-400',
  '생산성': 'bg-emerald-400',
  '디자인': 'bg-violet-400',
};

const avatarColors: Record<string, string> = {
  '다다': '#FBE830',
  '비비안': '#a78bfa',
  '띵끄': '#34d399',
  '에밀리': '#f472b6',
  '오웬': '#60a5fa',
  '흐민': '#818cf8',
  '다니': '#fb923c',
  '잽': '#f87171',
  '젬마': '#2dd4bf',
};

function cleanTitle(title: string | null | undefined, id: string): string {
  if (title && title.trim()) return title;
  return id.replace(/[-_]/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}
---
<Layout title="스킬 & 인사이트 - AAA TEAM">
  <!-- Hero -->
  <section class="pt-20 md:pt-24" style="background: linear-gradient(135deg, rgba(251,232,48,0.06) 0%, rgba(251,232,48,0.12) 50%, transparent 100%);">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 pt-8 md:pt-10 pb-6 md:pb-8">
      <div class="flex items-baseline gap-3 mb-2">
        <h1 class="font-headline text-2xl md:text-3xl font-extrabold tracking-tight text-black dark:text-white">스킬 & 인사이트</h1>
        <span class="text-sm font-bold text-[#FBE830]">{skills.length}</span>
      </div>
      <p class="text-sm text-slate-500 dark:text-gray-400">멤버들이 실전에서 발견한 도구, 스킬, 인사이트를 공유합니다.</p>
    </div>
  </section>

  <!-- Category Filter -->
  <section class="bg-white dark:bg-[#131315] border-b border-slate-100 dark:border-[#353437] sticky top-14 md:top-16 z-40">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12">
      <div class="flex gap-2 overflow-x-auto py-3 scrollbar-hide">
        <button class="filter-btn active whitespace-nowrap text-sm font-bold px-4 py-1.5 rounded-full transition-all" data-category="all">
          전체
        </button>
        {categories.map(cat => (
          <button class="filter-btn whitespace-nowrap text-sm font-medium px-4 py-1.5 rounded-full transition-all flex items-center gap-1.5" data-category={cat}>
            <span class={`w-1.5 h-1.5 rounded-full ${dotColors[cat] || 'bg-slate-400'}`}></span>
            {cat}
            <span class="text-[10px] opacity-50">{catCounts[cat]}</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Cards -->
  <section class="bg-slate-50/50 dark:bg-[#0e0e10]">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 py-8 md:py-12">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="skills-grid">
        {skills.map(skill => {
          const title = cleanTitle(skill.data.title, skill.id);
          const author = skill.data.author && skill.data.author !== 'AAA Team' ? skill.data.author : '';
          const accent = accentColors[skill.data.category || ''] || '#94a3b8';
          const avatarBg = author ? (avatarColors[author] || '#94a3b8') : '#d1d5db';
          return (
          <a href={`${base}tools/${skill.id}/`} class="skill-card block bg-white dark:bg-[#1b1b1d] rounded-xl border border-slate-200/80 dark:border-[#2a2a2d] hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 overflow-hidden group" data-category={skill.data.category || '기타'}>
            {/* Category accent bar */}
            <div class="h-1" style={`background: ${accent};`}></div>

            <div class="p-5">
              {/* Top: Category + Author */}
              <div class="flex items-center justify-between mb-3">
                <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400 dark:text-gray-500">{skill.data.category || '기타'}</span>
                {author && (
                  <div class="flex items-center gap-1.5">
                    <div class="w-4 h-4 rounded-full flex items-center justify-center text-[7px] font-black text-white" style={`background: ${avatarBg};`}>
                      {author.charAt(0)}
                    </div>
                    <span class="text-[10px] font-medium text-slate-400 dark:text-gray-500">{author}</span>
                  </div>
                )}
              </div>

              {/* Title */}
              <h3 class="font-headline text-[15px] font-bold text-black dark:text-white mb-2 leading-snug group-hover:text-[#b8960a] dark:group-hover:text-[#FBE830] transition-colors line-clamp-2">{title}</h3>

              {/* Summary */}
              <p class="text-xs text-slate-500 dark:text-gray-400 leading-relaxed line-clamp-2 mb-4">
                {skill.data.summary || '자세한 내용은 클릭해서 확인하세요.'}
              </p>

              {/* Keywords */}
              {skill.data.keywords && skill.data.keywords.length > 0 && (skill.data.keywords as string[])[0] !== skill.data.category && (
                <div class="flex flex-wrap gap-1 mb-4">
                  {(skill.data.keywords as string[]).slice(0, 4).map((kw: string) => (
                    <span class="text-[9px] font-medium px-2 py-0.5 rounded bg-slate-100 dark:bg-[#252527] text-slate-500 dark:text-gray-400">{kw}</span>
                  ))}
                </div>
              )}

              {/* Footer */}
              <div class="flex items-center justify-between pt-3 border-t border-slate-100 dark:border-[#252527]">
                {skill.data.link ? (
                  <span class="text-[10px] text-slate-400 dark:text-gray-500 flex items-center gap-0.5">
                    <span class="material-symbols-outlined text-xs">link</span>
                    외부 링크
                  </span>
                ) : (
                  <span></span>
                )}
                <span class="text-[10px] font-bold text-slate-400 dark:text-gray-500 group-hover:text-[#b8960a] dark:group-hover:text-[#FBE830] transition-colors flex items-center gap-0.5 uppercase tracking-wider">
                  자세히보기
                  <span class="material-symbols-outlined text-xs">east</span>
                </span>
              </div>
            </div>
          </a>
          );
        })}
      </div>

      <div id="empty-state" class="hidden text-center py-16">
        <span class="material-symbols-outlined text-slate-300 dark:text-gray-600 text-5xl block mb-4">search_off</span>
        <p class="text-slate-400 dark:text-gray-500 text-sm">해당 카테고리의 항목이 없습니다.</p>
      </div>
    </div>
  </section>

  <style>
    .filter-btn {
      background: transparent;
      color: #6b7280;
      border: 1px solid #e5e7eb;
    }
    .filter-btn:hover {
      background: #f8fafc;
      color: #000;
      border-color: #d1d5db;
    }
    .filter-btn.active {
      background: #FBE830;
      color: #000;
      font-weight: 700;
      border-color: #FBE830;
    }
    :global(.dark) .filter-btn {
      color: #9ca3af;
      border-color: #353437;
    }
    :global(.dark) .filter-btn:hover {
      background: #1b1b1d;
      color: #fff;
      border-color: #555;
    }
    :global(.dark) .filter-btn.active {
      background: #FBE830;
      color: #000;
      border-color: #FBE830;
    }
    .skill-card.hidden-by-filter {
      display: none;
    }
    .scrollbar-hide::-webkit-scrollbar {
      display: none;
    }
    .scrollbar-hide {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const buttons = document.querySelectorAll('.filter-btn');
      const items = document.querySelectorAll('.skill-card');
      const emptyState = document.getElementById('empty-state');

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          const category = btn.getAttribute('data-category');
          if (!category) return;

          buttons.forEach(b => {
            if (b.getAttribute('data-category')) b.classList.remove('active');
          });
          document.querySelectorAll(`.filter-btn[data-category="${category}"]`).forEach(b => b.classList.add('active'));

          let visibleCount = 0;
          items.forEach(item => {
            if (category === 'all' || item.getAttribute('data-category') === category) {
              item.classList.remove('hidden-by-filter');
              visibleCount++;
            } else {
              item.classList.add('hidden-by-filter');
            }
          });

          if (emptyState) emptyState.classList.toggle('hidden', visibleCount > 0);
        });
      });
    });
  </script>
</Layout>
