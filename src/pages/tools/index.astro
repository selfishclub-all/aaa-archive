---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';
const skills = await getCollection('skills');
const base = import.meta.env.BASE_URL;
const categories = [...new Set(skills.map(s => s.data.category).filter(Boolean))];

const catCounts: Record<string, number> = {};
categories.forEach(cat => {
  catCounts[cat] = skills.filter(s => s.data.category === cat).length;
});

const dotColors: Record<string, string> = {
  '자동화': 'bg-[#FBE830]',
  '콘텐츠': 'bg-black dark:bg-white',
  '분석': 'bg-slate-400',
  '생산성': 'bg-emerald-400',
  '디자인': 'bg-violet-400',
};
---
<Layout title="스킬 & 인사이트 - AAA TEAM">
  <!-- Hero -->
  <section class="pt-20 md:pt-24" style="background: linear-gradient(135deg, rgba(251,232,48,0.08) 0%, rgba(251,232,48,0.15) 40%, rgba(200,240,200,0.1) 100%);">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 pt-8 md:pt-10 pb-8 md:pb-10">
      <h1 class="font-headline text-2xl md:text-3xl font-extrabold tracking-tight text-black dark:text-white mb-2">스킬 & 인사이트</h1>
      <p class="text-sm md:text-base text-slate-600 dark:text-gray-400">멤버들이 <strong class="text-black dark:text-white">실전에서 발견</strong>한 도구, 스킬, 인사이트를 공유합니다.</p>
    </div>
  </section>

  <!-- Category Filter -->
  <section class="bg-white dark:bg-[#131315] border-b border-slate-100 dark:border-[#353437] sticky top-14 md:top-16 z-40">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12">
      <div class="flex gap-2 overflow-x-auto py-3 -mx-1 scrollbar-hide">
        <button class="filter-btn active whitespace-nowrap text-sm font-bold px-5 py-2 rounded-full transition-all" data-category="all">
          전체 <span class="text-xs font-normal ml-1 opacity-60">{skills.length}</span>
        </button>
        {categories.map(cat => (
          <button class="filter-btn whitespace-nowrap text-sm font-medium px-5 py-2 rounded-full transition-all flex items-center gap-1.5" data-category={cat}>
            <span class={`w-2 h-2 rounded-full ${dotColors[cat] || 'bg-slate-400'}`}></span>
            {cat}
            <span class="text-xs font-normal opacity-60">{catCounts[cat]}</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Cards -->
  <section class="bg-white dark:bg-[#131315]">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 py-8 md:py-12">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="skills-grid">
        {skills.map(skill => (
          <div class="skill-card p-5 bg-slate-50 dark:bg-[#1b1b1d] border border-slate-100 dark:border-[#353437] rounded-xl hover:border-[#FBE830]/30 hover:shadow-md transition-all group" data-category={skill.data.category || '기타'}>
            {/* Keywords */}
            {skill.data.keywords && skill.data.keywords.length > 0 && (
              <div class="flex flex-wrap gap-1.5 mb-3">
                {(skill.data.keywords as string[]).slice(0, 3).map((kw: string) => (
                  <span class="text-[10px] font-medium px-2 py-0.5 rounded-full bg-white dark:bg-[#252527] text-slate-500 dark:text-gray-400 border border-slate-200 dark:border-[#353437]">{kw}</span>
                ))}
              </div>
            )}

            {/* Title */}
            <h3 class="font-headline text-sm font-bold text-black dark:text-white mb-2 line-clamp-1">{skill.data.title || skill.id}</h3>

            {/* Summary */}
            {skill.data.summary && (
              <p class="text-xs text-slate-500 dark:text-gray-400 leading-relaxed mb-4 line-clamp-2">{skill.data.summary}</p>
            )}

            {/* Footer: Author + Actions */}
            <div class="flex items-center justify-between pt-3 border-t border-slate-100 dark:border-[#353437]">
              <div class="flex items-center gap-2">
                <div class="w-5 h-5 bg-white dark:bg-[#252527] rounded-full flex items-center justify-center">
                  <span class="text-[8px] font-bold text-slate-500 dark:text-gray-400">{(skill.data.author || '?').charAt(0)}</span>
                </div>
                <span class="text-[11px] text-slate-400 dark:text-gray-500">{skill.data.author || '멤버'}</span>
              </div>
              <div class="flex items-center gap-2">
                {skill.data.link && (
                  <a href={skill.data.link} target="_blank" rel="noopener" class="text-[11px] font-medium text-slate-400 hover:text-[#d4a800] dark:hover:text-[#FBE830] transition-colors flex items-center gap-0.5" onclick="event.stopPropagation()">
                    <span class="material-symbols-outlined text-sm">link</span>
                    링크
                  </a>
                )}
                <a href={`${base}tools/${skill.id}/`} class="text-[11px] font-medium text-slate-400 hover:text-[#d4a800] dark:hover:text-[#FBE830] transition-colors flex items-center gap-0.5">
                  자세히보기
                  <span class="material-symbols-outlined text-sm">arrow_forward</span>
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div id="empty-state" class="hidden text-center py-16">
        <span class="material-symbols-outlined text-slate-300 dark:text-gray-600 text-5xl block mb-4">search_off</span>
        <p class="text-slate-400 dark:text-gray-500">해당 카테고리의 항목이 없습니다.</p>
      </div>
    </div>
  </section>

  <style>
    .filter-btn {
      background: transparent;
      color: #6b7280;
      border: 1px solid #e5e7eb;
    }
    .filter-btn:hover {
      background: #f8fafc;
      color: #000;
      border-color: #d1d5db;
    }
    .filter-btn.active {
      background: #FBE830;
      color: #000;
      font-weight: 700;
      border-color: #FBE830;
    }
    :global(.dark) .filter-btn {
      color: #9ca3af;
      border-color: #353437;
    }
    :global(.dark) .filter-btn:hover {
      background: #1b1b1d;
      color: #fff;
      border-color: #555;
    }
    :global(.dark) .filter-btn.active {
      background: #FBE830;
      color: #000;
      border-color: #FBE830;
    }
    .skill-card.hidden-by-filter {
      display: none;
    }
    .scrollbar-hide::-webkit-scrollbar {
      display: none;
    }
    .scrollbar-hide {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const buttons = document.querySelectorAll('.filter-btn');
      const items = document.querySelectorAll('.skill-card');
      const emptyState = document.getElementById('empty-state');

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          const category = btn.getAttribute('data-category');
          if (!category) return;

          buttons.forEach(b => {
            if (b.getAttribute('data-category')) b.classList.remove('active');
          });
          document.querySelectorAll(`.filter-btn[data-category="${category}"]`).forEach(b => b.classList.add('active'));

          let visibleCount = 0;
          items.forEach(item => {
            if (category === 'all' || item.getAttribute('data-category') === category) {
              item.classList.remove('hidden-by-filter');
              visibleCount++;
            } else {
              item.classList.add('hidden-by-filter');
            }
          });

          if (emptyState) emptyState.classList.toggle('hidden', visibleCount > 0);
        });
      });
    });
  </script>
</Layout>
