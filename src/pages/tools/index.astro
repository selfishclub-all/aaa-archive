---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';
const tools = await getCollection('tools');
const base = import.meta.env.BASE_URL;
const categories = [...new Set(tools.map(t => t.data.category).filter(Boolean))];

const catCounts: Record<string, number> = {};
categories.forEach(cat => {
  catCounts[cat] = tools.filter(t => t.data.category === cat).length;
});

const iconMap: Record<string, string> = {
  '자동화': 'architecture',
  '콘텐츠': 'filter_alt',
  '분석': 'hub',
  '생산성': 'analytics',
  '디자인': 'palette',
};

const dotColors: Record<string, string> = {
  '자동화': 'bg-[#FBE830]',
  '콘텐츠': 'bg-black dark:bg-white',
  '분석': 'bg-slate-400',
  '생산성': 'bg-emerald-400',
  '디자인': 'bg-violet-400',
};
---
<Layout title="도구 모음 - AAA 아카이브">
  <!-- Hero Banner -->
  <section class="pt-20 md:pt-24" style="background: linear-gradient(135deg, rgba(251,232,48,0.08) 0%, rgba(251,232,48,0.15) 40%, rgba(200,240,200,0.1) 100%);">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 pt-8 md:pt-10 pb-8 md:pb-10">
      <h1 class="font-headline text-2xl md:text-3xl font-extrabold tracking-tight text-black dark:text-white mb-2">도구 모음</h1>
      <p class="text-sm md:text-base text-slate-600 dark:text-gray-400 mb-4">멤버들이 <strong class="text-black dark:text-white">실전에서 검증</strong>한 도구와 스킬셋 모음.</p>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1 text-xs font-medium border border-slate-200 dark:border-[#353437] rounded-full text-slate-600 dark:text-gray-400 bg-white/60 dark:bg-[#1b1b1d]/60">#스킬</span>
        <span class="px-3 py-1 text-xs font-medium border border-slate-200 dark:border-[#353437] rounded-full text-slate-600 dark:text-gray-400 bg-white/60 dark:bg-[#1b1b1d]/60">#플러그인</span>
        <span class="px-3 py-1 text-xs font-medium border border-slate-200 dark:border-[#353437] rounded-full text-slate-600 dark:text-gray-400 bg-white/60 dark:bg-[#1b1b1d]/60">#자동화</span>
      </div>
    </div>
  </section>

  <!-- Category Filter -->
  <section class="bg-white dark:bg-[#131315] border-b border-slate-100 dark:border-[#353437] sticky top-14 md:top-16 z-40">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12">
      <div class="flex gap-2 overflow-x-auto py-3 -mx-1 scrollbar-hide">
        <button class="filter-btn active whitespace-nowrap text-sm font-bold px-5 py-2 rounded-full transition-all" data-category="all">
          전체 <span class="text-xs font-normal ml-1 opacity-60">{tools.length}</span>
        </button>
        {categories.map(cat => (
          <button class="filter-btn whitespace-nowrap text-sm font-medium px-5 py-2 rounded-full transition-all flex items-center gap-1.5" data-category={cat}>
            <span class={`w-2 h-2 rounded-full ${dotColors[cat] || 'bg-slate-400'}`}></span>
            {cat}
            <span class="text-xs font-normal opacity-60">{catCounts[cat]}</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Tools List -->
  <section class="bg-white dark:bg-[#131315]">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 py-8 md:py-12">
      <div class="space-y-2" id="tools-grid">
        {tools.map(tool => (
          <a href={`${base}tools/${tool.id}/`} class="tool-item flex items-center gap-4 px-5 py-3.5 rounded-lg hover:bg-slate-50 dark:hover:bg-[#1b1b1d] transition-all group border border-transparent hover:border-[#FBE830]/30 block" data-category={tool.data.category || '기타'}>
            <span class="material-symbols-outlined text-slate-400 dark:text-gray-500 group-hover:text-[#d4a800] dark:group-hover:text-[#FBE830] text-xl transition-colors" style="font-variation-settings: 'FILL' 1;">{iconMap[tool.data.category || ''] || 'handyman'}</span>
            <div class="flex-1 min-w-0">
              <h4 class="text-sm font-bold text-black dark:text-white group-hover:text-[#d4a800] dark:group-hover:text-[#FBE830] transition-colors truncate">{tool.data.name || tool.id}</h4>
            </div>
            {tool.data.category && (
              <span class="text-[10px] font-medium text-slate-500 dark:text-gray-400 hidden md:inline">{Array.isArray(tool.data.category) ? tool.data.category.join(', ') : tool.data.category}</span>
            )}
            <span class="material-symbols-outlined text-slate-300 dark:text-gray-600 text-base">chevron_right</span>
          </a>
        ))}
      </div>

      <div id="empty-state" class="hidden text-center py-16">
        <span class="material-symbols-outlined text-slate-300 dark:text-gray-600 text-5xl block mb-4">search_off</span>
        <p class="text-slate-400 dark:text-gray-500">해당 카테고리의 도구가 없습니다.</p>
      </div>
    </div>
  </section>

  <style>
    .filter-btn {
      background: transparent;
      color: #6b7280;
      border: 1px solid #e5e7eb;
    }
    .filter-btn:hover {
      background: #f8fafc;
      color: #000;
      border-color: #d1d5db;
    }
    .filter-btn.active {
      background: #FBE830;
      color: #000;
      font-weight: 700;
      border-color: #FBE830;
    }
    :global(.dark) .filter-btn {
      color: #9ca3af;
      border-color: #353437;
    }
    :global(.dark) .filter-btn:hover {
      background: #1b1b1d;
      color: #fff;
      border-color: #555;
    }
    :global(.dark) .filter-btn.active {
      background: #FBE830;
      color: #000;
      border-color: #FBE830;
    }
    .tool-item.hidden-by-filter {
      display: none;
    }
    .scrollbar-hide::-webkit-scrollbar {
      display: none;
    }
    .scrollbar-hide {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const buttons = document.querySelectorAll('.filter-btn');
      const items = document.querySelectorAll('.tool-item');
      const emptyState = document.getElementById('empty-state');

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          const category = btn.getAttribute('data-category');
          if (!category) return;

          buttons.forEach(b => {
            if (b.getAttribute('data-category')) b.classList.remove('active');
          });
          document.querySelectorAll(`.filter-btn[data-category="${category}"]`).forEach(b => b.classList.add('active'));

          let visibleCount = 0;
          items.forEach(item => {
            if (category === 'all' || item.getAttribute('data-category') === category) {
              item.classList.remove('hidden-by-filter');
              visibleCount++;
            } else {
              item.classList.add('hidden-by-filter');
            }
          });

          if (emptyState) emptyState.classList.toggle('hidden', visibleCount > 0);
        });
      });
    });
  </script>
</Layout>
