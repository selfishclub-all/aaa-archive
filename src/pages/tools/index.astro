---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';
const tools = await getCollection('tools');
const base = import.meta.env.BASE_URL;
const categories = [...new Set(tools.map(t => t.data.category).filter(Boolean))];
---
<Layout title="도구 모음 - AAA 아카이브">
  <section class="py-24 px-6 md:px-16 max-w-[1440px] mx-auto">
    <span class="text-primary-fixed font-headline text-xs uppercase tracking-[0.3em] font-bold mb-4 block">Tools</span>
    <h1 class="font-headline text-4xl md:text-5xl font-bold mb-16">도구 모음</h1>
    {categories.length > 0 ? categories.map(cat => (
      <div class="mb-16">
        <h2 class="font-headline text-2xl font-bold mb-8 text-primary-fixed">{cat}</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {tools.filter(t => t.data.category === cat).map(tool => (
            <a href={`${base}tools/${tool.id}/`} class="bg-surface-high p-8 rounded-xl hover:translate-y-[-4px] transition-transform duration-300 block">
              <h4 class="font-headline text-lg font-bold mb-2">{tool.data.name || tool.id}</h4>
              <p class="text-on-surface/40 text-sm mb-4">{tool.data.type || ''}</p>
              {tool.data.difficulty && <span class="bg-primary-container/10 text-primary-fixed px-3 py-1 rounded-full text-[10px] font-bold uppercase">{tool.data.difficulty}</span>}
            </a>
          ))}
        </div>
      </div>
    )) : (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {tools.map(tool => (
          <a href={`${base}tools/${tool.id}/`} class="bg-surface-high p-8 rounded-xl hover:translate-y-[-4px] transition-transform duration-300 block">
            <h4 class="font-headline text-lg font-bold mb-2">{tool.data.name || tool.id}</h4>
            <p class="text-on-surface/40 text-sm mb-4">{tool.data.type || ''}</p>
          </a>
        ))}
      </div>
    )}
  </section>
</Layout>
