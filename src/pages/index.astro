---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;

// 최근 주차 미션 데이터
const latestWeek = {
  week: 3,
  title: '자동화를 넘어 실제 서비스 배포',
  members: [
    { name: '다다', cardTitle: '스터디 운영시스템 + 웹사이트 구축', summary: '커스텀 스킬 5개 생성. Quartz에서 Astro로 마이그레이션.', link: '' },
    { name: '비비안', cardTitle: '셀피쉬클럽 v4.0 자체 플랫폼 셋업', summary: 'Webflow→Next.js 마이그레이션. 문서 우선 개발.', link: '' },
    { name: '띵끄', cardTitle: 'YFLOW 전체 감사 — 5개 에이전트', summary: 'God Component 2,188줄→186줄. Vitest 31개 테스트.', link: 'https://github.com/growththink/flowops-dashboard' },
    { name: '에밀리', cardTitle: 'CRM 알림톡 실제 발송 자동화', summary: 'n8n 알림톡 전체 플로우 성공. PRD 8개 분리.', link: '' },
    { name: '오웬', cardTitle: '찜마켓 — 안전한 맞찜 플랫폼', summary: '카카오 로그인 + 스크린샷 인증 + 신뢰 온도.', link: 'https://zzim-exchange.vercel.app' },
    { name: '흐민', cardTitle: 'Sullivan + Personal Brand OS', summary: 'Agent Mode 추가. 마크다운 에이전트 전환.', link: '' },
  ]
};
---

<Layout title="AAA TEAM by Selfish Club">
  <!-- Hero (compact) -->
  <section class="pt-14 md:pt-16" style="background: linear-gradient(135deg, rgba(251,232,48,0.08) 0%, rgba(251,232,48,0.15) 40%, rgba(200,240,200,0.1) 100%);">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 pt-10 md:pt-14 pb-8 md:pb-10 text-center">
      <span class="inline-block py-1 px-3 bg-white/60 dark:bg-[#1b1b1d]/60 text-slate-500 dark:text-gray-400 text-[10px] font-bold tracking-[0.2em] uppercase mb-4 rounded border border-slate-200 dark:border-[#353437]">Selfish Club × AAA TEAM</span>
      <h1 class="font-headline text-3xl md:text-5xl font-extrabold text-black dark:text-white leading-[1.1] tracking-tighter mb-4 mx-auto">
        이기적으로 만들고,<br/>이기적으로 공유한다.
      </h1>
      <p class="text-sm md:text-base text-slate-600 dark:text-gray-400 max-w-lg mx-auto leading-relaxed">
        셀피쉬클럽이 만든 AAA TEAM.<br/>매주 AI로 실전 프로젝트를 빌드하고,<br/>그 과정을 낱낱이 공유합니다.
      </p>
    </div>
  </section>

  <!-- Latest Weekly Mission -->
  <section class="bg-white dark:bg-[#131315]">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 pt-12 md:pt-16 pb-16 md:pb-20">
      <div class="flex items-center justify-between mb-8">
        <div class="flex items-baseline gap-3">
          <span class="text-3xl md:text-4xl font-headline font-black text-[#FBE830]">W{String(latestWeek.week).padStart(2, '0')}</span>
          <div>
            <h2 class="text-lg md:text-xl font-bold text-black dark:text-white tracking-tight">{latestWeek.title}</h2>
            <p class="text-xs text-slate-400 dark:text-gray-500">{latestWeek.members.length}명 참여</p>
          </div>
        </div>
        <a href={`${base}archive/`} class="text-xs font-bold text-slate-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors flex items-center gap-1">
          전체 보기
          <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {latestWeek.members.map((member) => (
          <div class="p-5 bg-slate-50 dark:bg-[#1b1b1d] border border-slate-100 dark:border-[#353437] rounded-xl hover:border-[#FBE830]/30 hover:shadow-md transition-all group">
            <h3 class="font-headline text-sm font-bold text-black dark:text-white mb-1.5 group-hover:text-[#b8960a] dark:group-hover:text-[#FBE830] transition-colors line-clamp-1">{member.cardTitle}</h3>
            <p class="text-xs text-slate-500 dark:text-gray-400 leading-relaxed mb-3 line-clamp-2">{member.summary}</p>
            <div class="flex items-center justify-between pt-3 border-t border-slate-100 dark:border-[#353437]">
              <div class="flex items-center gap-2">
                <div class="w-5 h-5 bg-white dark:bg-[#252527] rounded-full flex items-center justify-center">
                  <span class="text-[8px] font-bold text-slate-500 dark:text-gray-400">{member.name.charAt(0)}</span>
                </div>
                <span class="text-[11px] text-slate-400 dark:text-gray-500">by {member.name}</span>
              </div>
              {member.link && (
                <a href={member.link} target="_blank" class="text-[10px] font-bold text-[#b8960a] dark:text-[#FBE830] hover:underline flex items-center gap-0.5" onclick="event.stopPropagation()">
                  <span class="material-symbols-outlined text-xs">open_in_new</span>
                  결과물
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="bg-slate-50 dark:bg-[#0e0e10] border-t border-slate-100 dark:border-[#353437]">
    <div class="max-w-2xl mx-auto px-6 md:px-12 py-16 md:py-24 text-center">
      <h2 class="font-headline text-2xl md:text-3xl font-extrabold text-black dark:text-white tracking-tight mb-3">Contact Us</h2>
      <p class="text-sm text-slate-500 dark:text-gray-400 mb-8">AAA TEAM에 대해 궁금한 점이 있다면 연락해주세요.</p>

      <form class="space-y-4 text-left" onsubmit="event.preventDefault(); document.getElementById('form-success').classList.remove('hidden'); this.reset();">
        <div>
          <label class="block text-xs font-bold text-slate-600 dark:text-gray-400 uppercase tracking-wider mb-1.5">이름</label>
          <input type="text" required class="w-full px-4 py-3 bg-white dark:bg-[#1b1b1d] border border-slate-200 dark:border-[#353437] rounded-lg text-sm text-black dark:text-white focus:outline-none focus:border-[#FBE830] transition-colors" placeholder="이름을 입력해주세요" />
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-600 dark:text-gray-400 uppercase tracking-wider mb-1.5">이메일</label>
          <input type="email" required class="w-full px-4 py-3 bg-white dark:bg-[#1b1b1d] border border-slate-200 dark:border-[#353437] rounded-lg text-sm text-black dark:text-white focus:outline-none focus:border-[#FBE830] transition-colors" placeholder="email@example.com" />
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-600 dark:text-gray-400 uppercase tracking-wider mb-1.5">메시지</label>
          <textarea rows="4" required class="w-full px-4 py-3 bg-white dark:bg-[#1b1b1d] border border-slate-200 dark:border-[#353437] rounded-lg text-sm text-black dark:text-white focus:outline-none focus:border-[#FBE830] transition-colors resize-none" placeholder="궁금한 점을 적어주세요"></textarea>
        </div>
        <button type="submit" class="w-full bg-[#FBE830] text-black font-bold py-3 px-6 rounded-lg text-sm hover:shadow-lg transition-all active:scale-[0.98]">
          보내기
        </button>
      </form>

      <div id="form-success" class="hidden mt-6 p-4 bg-[#FBE830]/10 border border-[#FBE830]/30 rounded-lg">
        <p class="text-sm font-medium text-[#b8960a] dark:text-[#FBE830]">메시지가 전송되었습니다. 감사합니다!</p>
      </div>
    </div>
  </section>
</Layout>
