---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';
import { marked } from 'marked';
import { getCollection } from 'astro:content';
const base = import.meta.env.BASE_URL;

// Tools & Insights for main page
const tools = await getCollection('tools');
const insights = await getCollection('insights');
const validInsights = insights.filter(i => {
  const title = i.id.replace(/[-_]/g, ' ').trim();
  return title && title !== '무제' && title.length > 1;
}).slice(0, 6);

const toolCategories = [...new Set(tools.flatMap(t => Array.isArray(t.data.category) ? t.data.category : [t.data.category]).filter(Boolean))];
const dotColors: Record<string, string> = {
  '자동화': 'bg-[#FBE830]',
  '콘텐츠': 'bg-black dark:bg-white',
  '분석': 'bg-slate-400',
  '생산성': 'bg-emerald-400',
  '디자인': 'bg-violet-400',
};
const iconMap: Record<string, string> = {
  '자동화': 'architecture',
  '콘텐츠': 'filter_alt',
  '분석': 'hub',
  '생산성': 'analytics',
  '디자인': 'palette',
};

const missionsDir = path.resolve('src/content/missions');
const getMissionHtml = (week: number, name: string): string => {
  const filename = `Week_0${week}_${name}.md`;
  const filepath = path.join(missionsDir, filename);
  try {
    const content = fs.readFileSync(filepath, 'utf8');
    const body = content.replace(/^---[\s\S]*?---\n?/, '');
    return body.trim() ? (marked.parse(body.trim()) as string) : '';
  } catch { return ''; }
};

// 최근 주차 미션 데이터
const latestWeek = {
  week: 5,
  title: '플랫폼 고도화와 자동화 파이프라인',
  members: [
    { name: '다다', cardTitle: 'AAA TEAM 공식 홈페이지', summary: 'Obsidian 콘텐츠 웹공개 + 어드민 + 배포 자동화.', link: 'https://aaa-homepage.vercel.app' },
    { name: '비비안', cardTitle: 'selfish-ax (셀피쉬클럽 v4.0)', summary: 'Notion 앱·카카오 로그인·결제·홈페이지 구축.', link: 'https://selfishclub-ax.vercel.app' },
    { name: '띵끄', cardTitle: 'GrowthLink — 비즈니스 통합 대시보드', summary: '5개 SaaS 통합 대시보드. 148커밋.', link: '' },
    { name: '에밀리', cardTitle: 'CRM 자동화 + 채널 카피 생성', summary: '알림톡 9종 자동 발송 + 채널 카피 자동화 완성.', link: '' },
    { name: '오웬', cardTitle: '찜마켓 — 안전 맞찜 플랫폼', summary: 'AI 스크린샷 인증 + 크레딧 경제. 146커밋.', link: 'https://zzim-exchange.vercel.app' },
    { name: '흐민', cardTitle: 'Selforge (Personal OS)', summary: 'Sullivan 영속 세션 + 지식 레이어 LLM 연동.', link: '' },
    { name: '다니', cardTitle: 'Remotion + Claude 영상 제작', summary: '코드로 영상 만들기 가이드 + 캐러셀 편집기.', link: 'https://zemma-carousel.vercel.app' },
  ]
};
---

<Layout title="AAA TEAM by Selfish Club">
  <!-- Hero (compact) -->
  <section class="pt-14 md:pt-16" style="background: linear-gradient(135deg, rgba(251,232,48,0.08) 0%, rgba(251,232,48,0.15) 40%, rgba(200,240,200,0.1) 100%);">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 py-12 md:py-16 flex flex-col items-center justify-center text-center">
      <span class="inline-block py-1 px-3 bg-white/60 dark:bg-[#1b1b1d]/60 text-slate-500 dark:text-gray-400 text-[10px] font-bold tracking-[0.2em] uppercase mb-4 rounded border border-slate-200 dark:border-[#353437]">Selfish Club × AAA TEAM</span>
      <h1 class="font-headline text-3xl md:text-5xl font-extrabold text-black dark:text-white leading-[1.1] tracking-tighter mb-4 mx-auto">
        이기적으로 만들고,<br/>이기적으로 공유한다.
      </h1>
      <p class="text-sm md:text-base text-slate-600 dark:text-gray-400 max-w-lg mx-auto leading-relaxed">
        셀피쉬클럽이 만든 AAA TEAM.<br/>매주 AI로 실전 프로젝트를 빌드하고,<br/>그 과정을 낱낱이 공유합니다.
      </p>
    </div>
  </section>

  <!-- Latest Weekly Mission -->
  <section class="bg-white dark:bg-[#131315]">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 pt-10 md:pt-12 pb-16 md:pb-20">
      <div class="flex items-center justify-between mb-8">
        <div class="flex items-baseline gap-3">
          <span class="text-3xl md:text-4xl font-headline font-black text-[#FBE830]">W{String(latestWeek.week).padStart(2, '0')}</span>
          <div>
            <h2 class="text-lg md:text-xl font-bold text-black dark:text-white tracking-tight">{latestWeek.title}</h2>
            <p class="text-xs text-slate-400 dark:text-gray-500">{latestWeek.members.length}명 참여</p>
          </div>
        </div>
        <a href={`${base}archive/`} class="text-xs font-bold text-slate-500 dark:text-gray-400 hover:text-black dark:hover:text-white transition-colors flex items-center gap-1">
          전체 보기
          <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {latestWeek.members.map((member) => {
          const fullHtml = getMissionHtml(latestWeek.week, member.name);
          const displayDetail = fullHtml || `<p>${member.summary}</p>`;
          return (
          <div
            class="p-5 bg-slate-50 dark:bg-[#1b1b1d] border border-slate-100 dark:border-[#353437] rounded-xl hover:border-[#FBE830]/30 hover:shadow-md transition-all group cursor-pointer main-card"
            data-name={member.name}
            data-title={member.cardTitle}
            data-detail={displayDetail}
            data-link={member.link || ''}
          >
            <h3 class="font-headline text-sm font-bold text-black dark:text-white mb-1.5 group-hover:text-[#b8960a] dark:group-hover:text-[#FBE830] transition-colors line-clamp-1">{member.cardTitle}</h3>
            <p class="text-xs text-slate-500 dark:text-gray-400 leading-relaxed mb-3 line-clamp-2">{member.summary}</p>
            <div class="flex items-center justify-between pt-3 border-t border-slate-100 dark:border-[#353437]">
              <div class="flex items-center gap-2">
                <div class="w-5 h-5 bg-white dark:bg-[#252527] rounded-full flex items-center justify-center">
                  <span class="text-[8px] font-bold text-slate-500 dark:text-gray-400">{member.name.charAt(0)}</span>
                </div>
                <span class="text-[11px] text-slate-400 dark:text-gray-500">by {member.name}</span>
              </div>
              {member.link && (
                <a href={member.link} target="_blank" class="text-[10px] font-bold text-[#b8960a] dark:text-[#FBE830] hover:underline flex items-center gap-0.5" onclick="event.stopPropagation()">
                  <span class="material-symbols-outlined text-xs">open_in_new</span>
                  결과물
                </a>
              )}
            </div>
          </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Modal -->
  <div id="main-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeMainModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-lg max-h-[80vh] overflow-y-auto bg-white dark:bg-[#1b1b1d] rounded-2xl shadow-2xl p-6 md:p-8">
      <button onclick="closeMainModal()" class="absolute top-4 right-4 text-slate-400 hover:text-black dark:hover:text-white transition-colors">
        <span class="material-symbols-outlined">close</span>
      </button>
      <h2 id="main-modal-title" class="font-headline text-xl font-bold text-black dark:text-white mb-3"></h2>
      <div id="main-modal-author" class="flex items-center gap-2 mb-5">
        <div class="w-6 h-6 bg-slate-100 dark:bg-[#252527] rounded-full flex items-center justify-center">
          <span id="main-modal-avatar" class="text-[9px] font-bold text-slate-500 dark:text-gray-400"></span>
        </div>
        <span id="main-modal-name" class="text-sm text-slate-500 dark:text-gray-400"></span>
      </div>
      <div id="main-modal-detail" class="prose prose-sm dark:prose-invert max-w-none mb-6 max-h-[50vh] overflow-y-auto [&_img]:rounded-lg [&_img]:my-4 [&_img]:max-w-full [&_video]:rounded-lg [&_video]:my-4 [&_video]:max-w-full"></div>
      <div id="main-modal-link-wrap" class="hidden">
        <a id="main-modal-link" href="#" target="_blank" class="inline-flex items-center gap-2 bg-[#FBE830] text-black font-bold py-3 px-6 rounded-lg text-sm hover:shadow-md transition-all">
          <span class="material-symbols-outlined text-sm">open_in_new</span>
          실제 결과물 보기
        </a>
      </div>
      <div class="mt-4 pt-4 border-t border-slate-100 dark:border-[#353437]">
        <a href={`${base}archive/`} class="text-xs font-bold text-slate-400 hover:text-black dark:hover:text-white transition-colors flex items-center gap-1">
          주간 미션 전체 보기
          <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>
      </div>
    </div>
  </div>

  <script is:inline>
    function closeMainModal() {
      document.getElementById('main-modal').classList.add('hidden');
      document.body.style.overflow = '';
    }
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMainModal(); });
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.main-card').forEach(card => {
        card.addEventListener('click', (e) => {
          if (e.target.closest('a')) return;
          const name = card.dataset.name;
          const title = card.dataset.title;
          const detail = card.dataset.detail;
          const link = card.dataset.link;
          document.getElementById('main-modal-title').textContent = title;
          document.getElementById('main-modal-avatar').textContent = name.charAt(0);
          document.getElementById('main-modal-name').textContent = 'by ' + name;
          document.getElementById('main-modal-detail').innerHTML = detail;
          const linkWrap = document.getElementById('main-modal-link-wrap');
          if (link) {
            document.getElementById('main-modal-link').href = link;
            linkWrap.classList.remove('hidden');
          } else {
            linkWrap.classList.add('hidden');
          }
          document.getElementById('main-modal').classList.remove('hidden');
          document.body.style.overflow = 'hidden';
        });
      });
    });
  </script>

  <!-- Contact -->
  <section id="contact" class="bg-slate-50 dark:bg-[#0e0e10] border-t border-slate-100 dark:border-[#353437]">
    <div class="max-w-2xl mx-auto px-6 md:px-12 py-16 md:py-24 text-center">
      <h2 class="font-headline text-2xl md:text-3xl font-extrabold text-black dark:text-white tracking-tight mb-3">Contact Us</h2>
      <p class="text-sm text-slate-500 dark:text-gray-400 mb-8">AAA TEAM에 대해 궁금한 점이 있다면 연락해주세요.</p>

      <form class="space-y-4 text-left" onsubmit="event.preventDefault(); document.getElementById('form-success').classList.remove('hidden'); this.reset();">
        <div>
          <label class="block text-xs font-bold text-slate-600 dark:text-gray-400 uppercase tracking-wider mb-1.5">이름</label>
          <input type="text" required class="w-full px-4 py-3 bg-white dark:bg-[#1b1b1d] border border-slate-200 dark:border-[#353437] rounded-lg text-sm text-black dark:text-white focus:outline-none focus:border-[#FBE830] transition-colors" placeholder="이름을 입력해주세요" />
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-600 dark:text-gray-400 uppercase tracking-wider mb-1.5">이메일</label>
          <input type="email" required class="w-full px-4 py-3 bg-white dark:bg-[#1b1b1d] border border-slate-200 dark:border-[#353437] rounded-lg text-sm text-black dark:text-white focus:outline-none focus:border-[#FBE830] transition-colors" placeholder="email@example.com" />
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-600 dark:text-gray-400 uppercase tracking-wider mb-1.5">메시지</label>
          <textarea rows="4" required class="w-full px-4 py-3 bg-white dark:bg-[#1b1b1d] border border-slate-200 dark:border-[#353437] rounded-lg text-sm text-black dark:text-white focus:outline-none focus:border-[#FBE830] transition-colors resize-none" placeholder="궁금한 점을 적어주세요"></textarea>
        </div>
        <button type="submit" class="w-full bg-[#FBE830] text-black font-bold py-3 px-6 rounded-lg text-sm hover:shadow-lg transition-all active:scale-[0.98]">
          보내기
        </button>
      </form>

      <div id="form-success" class="hidden mt-6 p-4 bg-[#FBE830]/10 border border-[#FBE830]/30 rounded-lg">
        <p class="text-sm font-medium text-[#b8960a] dark:text-[#FBE830]">메시지가 전송되었습니다. 감사합니다!</p>
      </div>
    </div>
  </section>
</Layout>
