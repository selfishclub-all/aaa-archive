---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import fs from 'node:fs';
import path from 'node:path';
import { marked } from 'marked';
const base = import.meta.env.BASE_URL;

// missions 파일을 직접 읽기 + 마크다운→HTML 변환
const missionsDir = path.resolve('src/content/missions');
const getMissionBody = (week: number, name: string): string => {
  const filename = `Week_0${week}_${name}.md`;
  const filepath = path.join(missionsDir, filename);
  try {
    const content = fs.readFileSync(filepath, 'utf8');
    // frontmatter 제거
    const body = content.replace(/^---[\s\S]*?---\n?/, '');
    return body.trim();
  } catch {
    return '';
  }
};
const getMissionHtml = (week: number, name: string): string => {
  const body = getMissionBody(week, name);
  if (!body) return '';
  return marked.parse(body) as string;
};

const weeks = [
  {
    week: 4,
    title: '실전 SaaS와 자동화의 완성',
    members: [
      { name: '다다', cardTitle: 'AAA TEAM 공식 홈페이지 + 어드민', summary: 'Obsidian vault 기반 외부 공개 사이트 구축. Vercel 배포.', detail: 'Obsidian vault에 멤버들이 작성한 과제, 인사이트, 도구 정보를 외부에 공개하는 웹사이트를 만들었다. 메인 랜딩, 주간 미션, 인사이트, 도구 모음, 갤러리, AI 분석, 팀소개 등 7개 페이지를 구축하고 Vercel로 배포했다. 어드민 페이지를 추가하여 frontmatter 기반 콘텐츠 관리 시스템을 구현했다.', icon: 'architecture', link: '' },
      { name: '비비안', cardTitle: '셀피쉬클럽 v4.0 — 토큰 효율화 + 인증', summary: 'CLAUDE.md 정비 + BetterAuth 카카오 로그인 구축. 하네스 엔지니어링으로 토큰 효율화.', detail: 'Claude Code가 읽는 설정 파일들을 정비하여 토큰 효율화를 선행했다. CLAUDE.md에 현재 진행 상황 섹션을 추가하고, AGENTS.md에 서브에이전트용 절대 규칙을 추가했다. BetterAuth + 카카오 OAuth를 연결하고 Supabase DB에 인증 테이블 4개를 생성했다. selfishclub-ax 전용 GitHub 레포를 연결하고 GitHub Actions 자동 동기화를 설정했다.', icon: 'engineering', link: '' },
      { name: '띵끄', cardTitle: 'GrowthLink — 비즈니스 통합 대시보드', summary: '148커밋, 26페이지, 67 API. Stripe·Calendly·GHL·Meta·n8n 5개 서비스 통합.', detail: '에이전시 사업 운영에 필요한 5~6개 툴(Stripe, Calendly, GoHighLevel, Meta, n8n)을 하나의 대시보드에서 통합 관리하는 SaaS GrowthLink(구 YFLOW)를 완성했다. 약 1개월간 148커밋, 26개 대시보드 페이지, 67개 API 엔드포인트, 20개+ DB 테이블을 구축했다. AI 인스타그램 캐러셀 생성기와 High-Ticket OS를 핵심 기능으로 포함했다.', icon: 'code', link: '' },
      { name: '에밀리', cardTitle: 'CRM 알림톡 9종 자동 발송 완성', summary: '알림톡 9종 + 카플친·오카방·온드미디어 카피 자동화. 크루 7명 실전 테스트.', detail: '공유회 하나당 각기 다른 템플릿 알림톡 9종(오픈알림, 리마인드, D-1, 당일, 할인쿠폰, 입장링크, 시작알림, 혜택안내, VOD)을 자동 발송하는 시스템을 완성했다. n8n 크론이 매일 아침 10시에 오늘 나가야 할 알림톡을 자동 확인한다. 카플친·오카방·온드미디어 카피 자동화와 랜딩페이지 작업까지 확장했다.', icon: 'campaign', link: '' },
      { name: '오웬', cardTitle: '찜마켓 — 146커밋 안전 맞찜 플랫폼', summary: 'AI 스크린샷 인증 + 크레딧 경제 + 셀러 커뮤니티. Microsoft Clarity 분석.', detail: '에이블리/지그재그/무신사 셀러 전용 안전 맞찜 플랫폼 찜마켓을 146커밋(feat 78/fix 57)으로 완성했다. 맞찜 전체 플로우(요청→수락→인증→AI 검증→완료), Claude Vision AI 스크린샷 자동 인증, 크레딧 경제 시스템, 셀러 커뮤니티, 실시간 알림을 구현했다. Microsoft Clarity 히트맵/세션리플레이로 분석 환경을 세팅했다.', icon: 'photo_camera', link: 'https://zzim-exchange.vercel.app' },
      { name: '흐민', cardTitle: 'Personal OS + Sullivan 마이그레이션', summary: 'Claude-Channel 마이그레이션. 3레이어 아키텍처 설계. 영속 세션 인프라.', detail: 'Sullivan의 동작 구조를 Claude-Channel 기능으로 마이그레이션하고, 재부팅 후에도 Sullivan이 자동으로 살아나는 영속 세션 인프라를 구축했다. Personal OS를 3레이어 아키텍처(사고·지식·퍼블리싱)로 설계하고, Karpathy LLM Wiki + Graphify를 리서치하여 적용했다. OmC Deep-Interview를 통해 요구사항을 구체화하고 리브랜딩했다.', icon: 'psychology', link: '' },
      { name: '다니', cardTitle: 'Remotion — 터미널에서 영상 만들기', summary: 'React + Claude Code로 자연어 영상 제작. 30~40분이면 첫 영상 완성.', detail: 'Remotion(React로 영상을 만드는 프레임워크)과 Claude Code를 결합하여 터미널에서 자연어로 영상을 만드는 워크플로우를 구축했다. After Effects나 프리미어 없이, 코드 한 줄도 안 건드리고 "이런 영상 만들어줘"라고 대화하면 AI가 코드를 짜고 브라우저에서 실시간 미리보기를 확인하며 수정할 수 있다. 총 30~40분이면 첫 영상까지 완성 가능.', icon: 'smart_toy', link: '' },
    ]
  },
  {
    week: 3,
    title: '자동화를 넘어 실제 서비스 배포',
    members: [
      { name: '다다', cardTitle: '스터디 운영시스템 + 웹사이트 구축', summary: '커스텀 스킬 5개 생성. Quartz에서 Astro로 마이그레이션. 도구의 한계를 먼저 파악하는 것이 중요하다는 인사이트.', detail: '약 6~7시간에 걸쳐 스터디 운영시스템을 설계하고 웹사이트를 구축했다. 커스텀 슬래시 명령어 5개(/analyze, /propose, /ln, /archive, /publish)를 만들어 운영 자동화를 구현했다. Quartz로 시작했으나 CSS 충돌이 반복되어 Astro로 마이그레이션했다. 핵심 인사이트: 증상(디자인 깨짐)만 보고 코드를 계속 고치지 말고, 도구 자체의 한계인지 먼저 의심해보자.', icon: 'architecture', link: '' },
      { name: '비비안', cardTitle: '셀피쉬클럽 v4.0 자체 플랫폼 셋업', summary: 'Webflow 의존을 끊고 Next.js 기반 자체 플랫폼 구축. BRIEFING.md + CLAUDE.md + DESIGN.md로 문서 우선 개발.', detail: '셀피쉬클럽 v4.0 리뉴얼을 위해 Webflow 의존을 끊고 Next.js 기반 자체 플랫폼을 구축하기 위한 초기 셋업을 완료했다. BRIEFING.md로 전체 기획을 Claude에게 전달하고, CLAUDE.md로 코딩 컨벤션을, DESIGN.md로 디자인 시스템을 정의했다. 기술 스택은 Next.js 16 + TypeScript + Tailwind CSS v4 + Vercel.', icon: 'engineering', link: '' },
      { name: '띵끄', cardTitle: 'YFLOW 전체 감사 — 5개 에이전트 동시 투입', summary: '5개 스프린트로 보안/성능/품질/접근성/구조 분석. God Component 2,188줄→186줄. Vitest 31개 테스트.', detail: 'team 5 명령으로 5개 전문 에이전트(Security, Performance, Code Review, A11y, Architecture)를 동시에 투입해 YFLOW 프로젝트를 전체 감사했다. 5개 스프린트로 나눠 보안 기반 → API 안전성 → 안정성 → 성능 → 접근성+테스트 순서로 진행했다. God Component 2,188줄을 186줄로 분리하고 Vitest 31개 테스트를 작성했다.', icon: 'code', link: 'https://github.com/growththink/flowops-dashboard' },
      { name: '에밀리', cardTitle: 'CRM 알림톡 실제 발송 자동화', summary: 'n8n 알림톡 ①~⑤ 전체 플로우 성공. 맥북 꺼져도 발송되는 하이브리드 아키텍처 재설계. PRD 8개 분리.', detail: '2주차에 만든 CRM 자동화를 실제 발송까지 연결했다. 맥북이 꺼져도 알림톡이 나가도록 n8n(서버)과 Claude Code(로컬)를 하이브리드로 재설계했다. n8n 크론을 재설계하여 줌링크 하나만 넣으면 나머지 4개 알림톡에서 자동 재사용하는 구조를 만들었다. CLAUDE.md 372줄을 PRD 8개로 분리하여 에이전트가 자기 채널만 읽도록 개선했다.', icon: 'campaign', link: '' },
      { name: '오웬', cardTitle: '찜마켓 — 안전한 맞찜 플랫폼', summary: '카카오 로그인 + 스크린샷 인증 + 신뢰 온도 + 크레딧 시스템. /briefing, /timecheck 스킬 2개 제작.', detail: '에이블리/지그재그/무신사 셀러를 위한 안전한 맞찜 플랫폼 \'찜마켓\'을 구축했다. 카카오 로그인, 스크린샷 인증, 당근 매너온도 방식의 신뢰 온도, 24시간 자동 환불 시스템을 구현했다. /briefing(자동 브리핑)과 /timecheck(작업 시간 추적) 스킬 2개를 제작하여 GitHub에 공개했다. 핵심 인사이트: 클로드의 위험성은 내가 똑똑한 것 아닐까라는 착각을 하게 되는 것.', icon: 'photo_camera', link: 'https://zzim-exchange.vercel.app' },
      { name: '흐민', cardTitle: 'Sullivan + Personal Brand OS', summary: 'Capture 에이전트 강화 + Agent Mode 추가. Python→마크다운 에이전트 전환. 오픈클로 + 로컬 LLM 연구.', detail: 'Sullivan의 Capture 에이전트를 대폭 강화하고 Agent Mode를 추가했다. 코드 레벨에서 대응 불가한 케이스에서 에러 대신 Agent를 호출하여 자동 해결하도록 세팅했다. Personal Brand OS를 구축하여 Obsidian 노트, 사진 등의 소스를 기반으로 다양한 플랫폼별 콘텐츠를 자동 생성하는 멀티에이전트 시스템을 만들었다. Python + Claude SDK에서 .claude/agents/*.md 마크다운 방식으로 전환했다.', icon: 'psychology', link: '' },
    ]
  },
  {
    week: 2,
    title: '원소스 멀티유즈의 폭발',
    members: [
      { name: '비비안', cardTitle: 'Webflow→Next.js 마이그레이션 설계', summary: '9단계로 체계적 분석. Supabase 락인 해결, Auth 방식 결정, 어드민 스펙 확정.', detail: '기존 Webflow 사이트의 구조, 페이지 목록, URL 패턴부터 분석하고 Supabase 락인 문제, Auth 방식, 결제 연동까지 하나씩 풀어나갔다. Magic Link에서 Clerk + 카카오 소셜 로그인으로 전환을 확정했다. 9단계에 걸친 체계적 분석 후 CLAUDE.md를 작성했다.', icon: 'engineering', link: '' },
