---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
const base = import.meta.env.BASE_URL;

const weeks = [
  {
    week: 3,
    title: '자동화를 넘어 실제 서비스 배포',
    members: [
      { name: '다다', summary: '스터디 운영시스템 + 웹사이트 구축. 커스텀 스킬 5개 생성. Quartz→Astro 마이그레이션.', icon: 'architecture', link: '' },
      { name: '비비안', summary: '셀피쉬클럽 v4.0 Next.js 기반 자체 플랫폼 초기 셋업. BRIEFING.md + CLAUDE.md + DESIGN.md 작성.', icon: 'engineering', link: '' },
      { name: '띵끄', summary: 'YFLOW 전체 감사 — 5개 에이전트 동시 투입, 5개 스프린트. God Component 2,188줄→186줄.', icon: 'code', link: 'https://github.com/growththink/flowops-dashboard' },
      { name: '에밀리', summary: 'CRM 자동화 실제 발송 연결. n8n 알림톡 ①~⑤ 성공. 맥북 꺼져도 발송되는 하이브리드 아키텍처.', icon: 'campaign', link: '' },
      { name: '오웬', summary: '찜마켓 — 안전한 맞찜 플랫폼. 카카오 로그인 + 신뢰 온도 + 크레딧 시스템. 스킬 2개 제작.', icon: 'photo_camera', link: 'https://zzim-exchange.vercel.app' },
      { name: '흐민', summary: 'Sullivan 아키텍처 강화 + Personal Brand OS. Python→마크다운 에이전트 전환. 오픈클로 연구.', icon: 'psychology', link: '' },
    ]
  },
  {
    week: 2,
    title: '원소스 멀티유즈의 폭발',
    members: [
      { name: '비비안', summary: 'Webflow→Next.js 마이그레이션 9단계 설계. Supabase 락인 해결, Auth 방식 결정.', icon: 'engineering', link: '' },
      { name: '띵끄', summary: '원소스 멀티유즈 콘텐츠 마케팅 사이트. OMC 활용, Vercel 자동배포.', icon: 'code', link: 'https://content-marketing-team.vercel.app/' },
      { name: '잽', summary: 'BRAND SHOW UP 원페이지 웹 제안서. 프레임워크 없이 순수 HTML/CSS/JS로 하루 만에 완성.', icon: 'web', link: 'https://zap-arch.github.io/brand-showup/' },
      { name: '흐민', summary: 'Sullivan — 질문으로 생각을 확장하는 AI. 5개 Agent + Obsidian 연동.', icon: 'psychology', link: '' },
      { name: '에밀리', summary: 'CRM 자동화. URL 하나로 8채널 20개 콘텐츠 자동 생성. 6개 에이전트 팀 설계.', icon: 'campaign', link: '' },
      { name: '다니', summary: '원소스 멀티유즈. URL로 인스타 캐러셀 + 스레드 + 링크드인 콘텐츠 자동 생성.', icon: 'smart_toy', link: '' },
      { name: '오웬', summary: '인스타그램 카드뉴스 자동 제작. crontab + Claude API + Playwright + instagrapi.', icon: 'photo_camera', link: '' },
    ]
  },
  {
    week: 1,
    title: 'Agent Loop에서 시작된 여정',
    members: [
      { name: '다다', summary: 'Claude Code CLI 설치 및 Agent Loop 학습. Obsidian vault 연동 성공.', icon: 'architecture', link: '' },
      { name: '비비안', summary: 'Agent Loop 구조 분석. 프롬프트 엔지니어링의 중요성 발견.', icon: 'engineering', link: '' },
    ]
  },
];
---
<Layout title="아카이브 - AAA 아카이브">
  <!-- Hero -->
  <section class="relative pt-24 md:pt-32 pb-16 md:pb-24 px-6 md:px-12 max-w-screen-2xl mx-auto overflow-hidden">
    <div class="flex flex-col md:flex-row items-end gap-12 border-l-2 border-slate-200 dark:border-[#353437] pl-8">
      <div class="max-w-4xl">
        <h1 class="font-headline text-5xl md:text-7xl lg:text-8xl font-light tracking-tighter leading-[1.1] text-black dark:text-white mb-8">
          What We <br/>
          <span class="font-extrabold italic text-black bg-[#FBE830] px-2 inline-block mt-4">Built.</span>
        </h1>
        <p class="text-lg md:text-xl text-slate-500 dark:text-gray-400 font-light max-w-2xl leading-relaxed">
          매주 만들고 배운 것들의 기록.<br/>아이디어가 프로젝트가 되는 과정을 아카이브합니다.
        </p>
      </div>
      <div class="hidden lg:block pb-4">
        <div class="flex items-center gap-4 text-xs uppercase tracking-[0.4em] text-slate-400 dark:text-gray-500" style="writing-mode: vertical-rl;">
          <span>Weekly Archive</span>
          <div class="w-px h-24 bg-slate-200 dark:bg-[#353437]"></div>
          <span>All Members</span>
        </div>
      </div>
    </div>
    <div class="absolute -right-24 top-0 w-96 h-96 bg-[#FBE830]/10 rounded-full blur-[120px] pointer-events-none"></div>
  </section>

  <!-- Weekly Archive -->
  <section class="pb-24 px-6 md:px-12 max-w-screen-2xl mx-auto">
    {weeks.map((week) => (
      <div class="mb-20">
        <div class="flex items-baseline gap-4 mb-8">
          <span class="text-4xl font-headline font-black text-[#FBE830]">W{String(week.week).padStart(2, '0')}</span>
          <div>
            <h2 class="text-xl md:text-2xl font-bold text-black dark:text-white tracking-tight">{week.title}</h2>
            <p class="text-sm text-slate-400 dark:text-gray-500">{week.members.length}명 참여</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {week.members.map((member) => (
            <div class="p-6 bg-slate-50 dark:bg-[#1b1b1d] border border-slate-100 dark:border-[#353437] rounded-xl hover:border-[#FBE830]/30 transition-all group">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-9 h-9 bg-white dark:bg-[#2a2a2c] rounded-lg flex items-center justify-center shadow-sm">
                  <span class="material-symbols-outlined text-slate-500 dark:text-gray-400 text-lg" style="font-variation-settings: 'FILL' 0, 'wght' 300;">{member.icon}</span>
                </div>
                <span class="font-headline font-bold text-black dark:text-white">{member.name}</span>
              </div>
              <p class="text-sm text-slate-500 dark:text-gray-400 leading-relaxed mb-3">{member.summary}</p>
              {member.link && (
                <a href={member.link} target="_blank" class="text-xs font-bold text-[#d4a800] dark:text-[#FBE830] hover:underline flex items-center gap-1">
                  <span class="material-symbols-outlined text-sm">open_in_new</span>
                  라이브 보기
                </a>
              )}
            </div>
          ))}
        </div>
      </div>
    ))}
  </section>
</Layout>
