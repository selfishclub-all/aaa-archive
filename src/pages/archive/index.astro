<Layout title="아카이브 - AAA 아카이브">
  <!-- Hero Banner -->
  <section class="pt-20 md:pt-24" style="background: linear-gradient(135deg, rgba(251,232,48,0.08) 0%, rgba(251,232,48,0.15) 40%, rgba(200,240,200,0.1) 100%);">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 pt-8 md:pt-10 pb-8 md:pb-10">
      <h1 class="font-headline text-2xl md:text-3xl font-extrabold tracking-tight text-black dark:text-white mb-2">주간 미션</h1>
      <p class="text-sm md:text-base text-slate-600 dark:text-gray-400 mb-4">매주 <strong class="text-black dark:text-white">만들고 배운 것들</strong>의 기록. 아이디어가 프로젝트가 되는 과정.</p>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1 text-xs font-medium border border-slate-200 dark:border-[#353437] rounded-full text-slate-600 dark:text-gray-400 bg-white/60 dark:bg-[#1b1b1d]/60">#주간과제</span>
        <span class="px-3 py-1 text-xs font-medium border border-slate-200 dark:border-[#353437] rounded-full text-slate-600 dark:text-gray-400 bg-white/60 dark:bg-[#1b1b1d]/60">#빌드로그</span>
        <span class="px-3 py-1 text-xs font-medium border border-slate-200 dark:border-[#353437] rounded-full text-slate-600 dark:text-gray-400 bg-white/60 dark:bg-[#1b1b1d]/60">#실전배포</span>
      </div>
    </div>
  </section>

  <!-- Weekly Archive -->
  <section class="pt-10 md:pt-12 pb-24 px-6 md:px-12 max-w-screen-2xl mx-auto">
    {weeks.map((week) => (
      <div class="mb-20">
        <div class="flex items-baseline gap-4 mb-8">
          <span class="text-4xl font-headline font-black text-[#FBE830]">W{String(week.week).padStart(2, '0')}</span>
          <div>
            <h2 class="text-xl md:text-2xl font-bold text-black dark:text-white tracking-tight">{week.title}</h2>
            <p class="text-sm text-slate-400 dark:text-gray-500">{week.members.length}명 참여</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {week.members.map((member) => {
            const fullHtml = getMissionHtml(week.week, member.name);
            const displayDetail = fullHtml || `<p>${member.detail || member.summary}</p>`;
            return (
            <div
              class="p-6 bg-slate-50 dark:bg-[#1b1b1d] border border-slate-100 dark:border-[#353437] rounded-xl hover:border-[#FBE830]/30 hover:shadow-lg transition-all group cursor-pointer flex flex-col modal-trigger"
              data-name={member.name}
              data-title={member.cardTitle}
              data-detail={displayDetail}
              data-link={member.link || ''}
            >
              <h3 class="font-headline text-base font-bold text-black dark:text-white mb-2 group-hover:text-[#d4a800] dark:group-hover:text-[#FBE830] transition-colors line-clamp-1">{member.cardTitle || member.summary}</h3>
              <p class="text-sm text-slate-500 dark:text-gray-400 leading-relaxed mb-4 line-clamp-2 flex-1">{member.summary}</p>
              <div class="flex items-center justify-between pt-3 border-t border-slate-100 dark:border-[#353437]">
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 bg-white dark:bg-[#2a2a2c] rounded-full flex items-center justify-center">
                    <span class="text-[9px] font-bold text-slate-500 dark:text-gray-400">{member.name.charAt(0)}</span>
                  </div>
                  <span class="text-xs text-slate-400 dark:text-gray-500">by {member.name}</span>
                </div>
                {member.link && (
                  <a href={member.link} target="_blank" class="text-[10px] font-bold text-[#d4a800] dark:text-[#FBE830] hover:underline flex items-center gap-1" onclick="event.stopPropagation()">
                    <span class="material-symbols-outlined text-xs">open_in_new</span>
                    결과물
                  </a>
                )}
              </div>
            </div>
          );
          })}
        </div>
      </div>
    ))}
  </section>

  <!-- Modal -->
  <div id="archive-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-2xl max-h-[80vh] overflow-y-auto bg-white dark:bg-[#1b1b1d] rounded-2xl shadow-2xl p-8 md:p-10">
      <button onclick="closeModal()" class="absolute top-4 right-4 text-slate-400 hover:text-black dark:hover:text-white transition-colors">
        <span class="material-symbols-outlined">close</span>
      </button>
      <h2 id="modal-title" class="font-headline text-2xl font-bold text-black dark:text-white mb-4"></h2>
      <div id="modal-author" class="flex items-center gap-2 mb-6">
        <div class="w-7 h-7 bg-slate-100 dark:bg-[#2a2a2c] rounded-full flex items-center justify-center">
          <span id="modal-avatar" class="text-[10px] font-bold text-slate-500 dark:text-gray-400"></span>
        </div>
        <span id="modal-name" class="text-sm text-slate-500 dark:text-gray-400"></span>
      </div>
      <div id="modal-detail" class="prose prose-sm dark:prose-invert max-w-none mb-6 max-h-[50vh] overflow-y-auto [&_img]:rounded-lg [&_img]:my-4 [&_img]:max-w-full"></div>
      <div id="modal-link-wrap" class="hidden">
        <a id="modal-link" href="#" target="_blank" class="inline-flex items-center gap-2 bg-[#FBE830] text-black font-bold py-3 px-6 rounded-lg text-sm hover:shadow-md transition-all">
          <span class="material-symbols-outlined text-sm">open_in_new</span>
          실제 결과물 보기
        </a>
      </div>
    </div>
  </div>

  <script is:inline>
    function openModal(name, title, detail, link) {
      document.getElementById('modal-title').textContent = title;
      document.getElementById('modal-avatar').textContent = name.charAt(0);
      document.getElementById('modal-name').textContent = 'by ' + name;
      document.getElementById('modal-detail').innerHTML = detail;
      const linkWrap = document.getElementById('modal-link-wrap');
      if (link) {
        document.getElementById('modal-link').href = link;
        linkWrap.classList.remove('hidden');
      } else {
        linkWrap.classList.add('hidden');
      }
      document.getElementById('archive-modal').classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
    function closeModal() {
      document.getElementById('archive-modal').classList.add('hidden');
      document.body.style.overflow = '';
    }
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.modal-trigger').forEach(card => {
        card.addEventListener('click', (e) => {
          if (e.target.closest('a')) return;
          openModal(
            card.dataset.name,
            card.dataset.title,
            card.dataset.detail,
            card.dataset.link
          );
        });
      });
    });
  </script>
</Layout>
