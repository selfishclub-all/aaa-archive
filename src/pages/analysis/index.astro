---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { getCollection, render } from 'astro:content';
const analysis = await getCollection('analysis');
const proposals = await getCollection('proposals');
const base = import.meta.env.BASE_URL;

const sorted = analysis.sort((a, b) => (b.data.week || 0) - (a.data.week || 0));
const latest = sorted[0];

// Insight-driven titles for each week
const weekTitles: Record<number, { title: string; desc: string }> = {
  6: { title: '개념이 각자의 시스템 로드맵으로 내려왔다', desc: '하네스·오케스트레이션이라는 같은 개념이 7개의 서로 다른 비유와 아키텍처로 번역됐다.' },
  5: { title: '만든 것을 전달하는 법을 배우다', desc: '7명이 각자의 프로젝트를 발표 가능한 형태로 정리했다. 만드는 것과 설명하는 것은 완전히 다른 근육이었다.' },
  4: { title: '시스템을 먼저 설계한 사람이 이겼다', desc: '기능을 먼저 만든 팀과 구조를 먼저 잡은 팀의 격차가 벌어졌다. 설계가 속도를 만들었다.' },
  3: { title: '자동화를 넘어 실제 서비스 배포', desc: '자동화의 완성은 파이프라인이 아니라 설계 철학이다.' },
  2: { title: '원소스 멀티유즈의 시대', desc: 'URL 하나로 8개 채널 콘텐츠를 자동 생성하는 시대가 왔다' },
  1: { title: 'Agent Loop에서 시작된 여정', desc: 'Claude Code의 기본 구조를 이해하고 첫 프로젝트를 만들다' },
};
---
<Layout title="AI 분석 - AAA 아카이브">
  <section class="pt-24 md:pt-32 pb-16 md:pb-24 px-6 md:px-12 max-w-7xl mx-auto">
    <!-- Hero Header -->
    <header class="mb-16 md:mb-20 grid grid-cols-1 lg:grid-cols-12 gap-8 items-end">
      <div class="lg:col-span-8">
        <div class="flex items-center gap-3 mb-6">
          <span class="bg-[#FBE830] text-black px-3 py-1 text-[10px] font-black uppercase tracking-widest rounded-sm">Research Report</span>
          <span class="text-sm font-medium text-slate-400 dark:text-gray-500 tracking-tight">AI AUTOMATION · WEEKLY ANALYSIS</span>
        </div>
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-headline font-extrabold tracking-tighter leading-[1.05] text-black dark:text-white mb-8">
          AAA Bot이 분석한<br/>스터디 인사이트
        </h1>
        <p class="text-lg md:text-xl font-light leading-relaxed max-w-2xl text-slate-500 dark:text-gray-400">
          매주 멤버들의 미션과 인사이트를 AI가 분석하여 핵심 트렌드, 키워드, 프로젝트 제안을 도출합니다.
        </p>
      </div>
      <div class="lg:col-span-4 flex justify-end">
        <div class="p-6 bg-[#131315] text-white rounded-xl w-full max-w-xs shadow-2xl rotate-1">
          <p class="text-sm font-headline font-bold text-[#FBE830] mb-4 uppercase tracking-[0.2em]">AAA Bot's Note</p>
          <p class="text-sm leading-relaxed italic opacity-70">
            "멤버들의 미션과 인사이트를 분석하여 핵심 트렌드를 추출합니다. 반복적인 운영 작업을 AI에게 맡기면 운영자는 콘텐츠 품질에만 집중할 수 있습니다."
          </p>
          <div class="mt-6 flex items-center gap-4">
            <div class="w-10 h-10 bg-[#2a2a2c] rounded-full flex items-center justify-center">
              <span class="material-symbols-outlined text-[#FBE830] text-sm">smart_toy</span>
            </div>
            <div>
              <p class="text-xs font-bold">AAA Bot</p>
              <p class="text-[10px] opacity-50 uppercase tracking-widest">Analysis Engine</p>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Content -->
    <div>
      <div class="space-y-16 max-w-3xl">
        {sorted.map((report, i) => {
          const week = report.data.week || 0;
          const info = weekTitles[week] || { title: `Week ${week} 분석`, desc: report.id.replace(/_/g, ' ') };
          return (
            <a href={`${base}analysis/${report.id}/`} class="block group">
              <section>
                <div class="flex items-baseline gap-4 mb-4">
                  <span class="text-4xl font-headline font-black text-[#FBE830]">{String(i + 1).padStart(2, '0')}</span>
                  <h2 class="text-xl md:text-2xl font-bold tracking-tight text-black dark:text-white group-hover:text-[#d4a800] dark:group-hover:text-[#FBE830] transition-colors">
                    {info.title}
                  </h2>
                </div>
                <div class="pl-14 border-l-2 border-[#FBE830]/20">
                  <p class="text-base leading-relaxed mb-4 text-slate-600 dark:text-gray-400">
                    {info.desc}
                  </p>
                </div>
              </section>
            </a>
          );
        })}
      </div>

    </div>

    <!-- What's Next Section -->
    <section class="mt-24 md:mt-32 pt-16 border-t border-slate-100 dark:border-[#353437]">
      <div class="flex items-baseline gap-4 mb-12">
        <span class="text-4xl font-headline font-black text-[#FBE830]">→</span>
        <div>
          <h2 class="text-2xl md:text-3xl font-headline font-extrabold text-black dark:text-white tracking-tight">다음에 만들어볼 것들</h2>
          <p class="text-sm text-slate-500 dark:text-gray-400 mt-2">AAA Bot이 분석 데이터에서 도출한 아이디어</p>
        </div>
      </div>
      {proposals.map((proposal, i) => (
        <a href={`${base}proposals/${proposal.id}/`} class="flex items-start gap-6 p-6 mb-4 rounded-xl hover:bg-slate-50 dark:hover:bg-[#1b1b1d] transition-all group block border-l-2 border-transparent hover:border-[#FBE830]">
          <div class="w-10 h-10 bg-[#FBE830]/10 rounded-lg flex items-center justify-center flex-shrink-0 mt-1">
            <span class="material-symbols-outlined text-[#d4a800] dark:text-[#FBE830] text-lg">
              {i === 0 ? 'smart_toy' : 'build'}
            </span>
          </div>
          <div>
            <h3 class="text-base font-bold text-black dark:text-white mb-1 group-hover:text-[#d4a800] dark:group-hover:text-[#FBE830] transition-colors">{proposal.id.replace(/_/g, ' ')}</h3>
            <p class="text-sm text-slate-500 dark:text-gray-400 leading-relaxed">클릭하여 상세 내용 보기 →</p>
          </div>
        </a>
      ))}
    </section>
  </section>
</Layout>
