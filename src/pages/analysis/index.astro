---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { getCollection, render } from 'astro:content';
const analysis = await getCollection('analysis');
const proposals = await getCollection('proposals');
const base = import.meta.env.BASE_URL;

const sorted = analysis.sort((a, b) => (b.data.week || 0) - (a.data.week || 0));
const latest = sorted[0];

// title/description은 frontmatter에서 직접 읽음
---
<Layout title="AI 분석 - AAA TEAM by Selfish Club">
  <!-- Hero Banner -->
  <section class="pt-14 md:pt-16" style="background: linear-gradient(135deg, rgba(251,232,48,0.08) 0%, rgba(251,232,48,0.15) 40%, rgba(200,240,200,0.1) 100%);">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 pt-8 md:pt-10 pb-8 md:pb-10">
      <h1 class="font-headline text-2xl md:text-3xl font-extrabold tracking-tight text-black dark:text-white mb-2">AI 분석</h1>
      <p class="text-sm md:text-base text-slate-600 dark:text-gray-400 mb-4">매주 멤버들의 미션과 인사이트를 <strong class="text-black dark:text-white">AI가 분석</strong>하여 핵심 트렌드를 도출합니다.</p>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1 text-xs font-medium border border-slate-200 dark:border-[#353437] rounded-full text-slate-600 dark:text-gray-400 bg-white/60 dark:bg-[#1b1b1d]/60">#AI분석</span>
        <span class="px-3 py-1 text-xs font-medium border border-slate-200 dark:border-[#353437] rounded-full text-slate-600 dark:text-gray-400 bg-white/60 dark:bg-[#1b1b1d]/60">#트렌드</span>
        <span class="px-3 py-1 text-xs font-medium border border-slate-200 dark:border-[#353437] rounded-full text-slate-600 dark:text-gray-400 bg-white/60 dark:bg-[#1b1b1d]/60">#주간리포트</span>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="px-6 md:px-12 max-w-7xl mx-auto pt-10 md:pt-12 pb-8">
    <!-- Content: Reports + Note sidebar -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 md:gap-16">
      <div class="lg:col-span-7 space-y-16">
        {sorted.map((report, i) => {
          const week = report.data.week || 0;
          const info = {
            title: report.data.title || `Week ${week} 분석`,
            desc: report.data.description || ''
          };
          return (
            <a href={`${base}analysis/${report.id}/`} class="block group">
              <section>
                <div class="flex items-baseline gap-4 mb-4">
                  <span class="text-4xl font-headline font-black text-[#FBE830]">{String(i + 1).padStart(2, '0')}</span>
                  <h2 class="text-xl md:text-2xl font-bold tracking-tight text-black dark:text-white group-hover:text-[#d4a800] dark:group-hover:text-[#FBE830] transition-colors">
                    {info.title}
                  </h2>
                </div>
                <div class="pl-14 border-l-2 border-[#FBE830]/20">
                  <p class="text-base leading-relaxed mb-4 text-slate-600 dark:text-gray-400">
                    {info.desc}
                  </p>
                </div>
              </section>
            </a>
          );
        })}
      </div>

      <!-- Note Sidebar -->
      <aside class="lg:col-span-5">
        <div class="p-8 bg-[#131315] text-[#e5e1e4] rounded-2xl sticky top-24">
          <p class="text-sm font-headline font-bold text-[#FBE830] mb-4 uppercase tracking-[0.2em]">AAA Bot's Note</p>
          <p class="text-sm leading-relaxed italic opacity-70">
            "멤버들의 미션과 인사이트를 분석하여 핵심 트렌드를 추출합니다. 반복적인 운영 작업을 AI에게 맡기면 운영자는 콘텐츠 품질에만 집중할 수 있습니다."
          </p>
          <div class="mt-8 flex items-center gap-4">
            <div class="w-10 h-10 bg-[#2a2a2c] rounded-full flex items-center justify-center">
              <span class="material-symbols-outlined text-[#FBE830] text-sm">smart_toy</span>
            </div>
            <div>
              <p class="text-xs font-bold">AAA Bot</p>
              <p class="text-[10px] opacity-50 uppercase tracking-widest">Analysis Engine</p>
            </div>
          </div>
        </div>
      </aside>
    </div>

    <!-- What's Next Section -->
    <section class="mt-24 md:mt-32 pt-16 border-t border-slate-100 dark:border-[#353437]">
      <div class="flex items-baseline gap-4 mb-12">
        <span class="text-4xl font-headline font-black text-[#FBE830]">→</span>
        <div>
          <h2 class="text-2xl md:text-3xl font-headline font-extrabold text-black dark:text-white tracking-tight">다음에 만들어볼 것들</h2>
          <p class="text-sm text-slate-500 dark:text-gray-400 mt-2">AAA Bot이 분석 데이터에서 도출한 아이디어</p>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {proposals.map((proposal, i) => {
          const title = proposal.id.replace(/_/g, ' ');
          const preview = proposal.data.preview as string | undefined;
          const highlights = (proposal.data.highlights as string[] | undefined) ?? [];
          const count = proposal.data.count as number | undefined;
          const icon = i === 0 ? 'smart_toy' : 'build';
          return (
            <a href={`${base}proposals/${proposal.id}/`} class="group block p-8 rounded-2xl border border-slate-100 dark:border-[#353437] hover:border-[#FBE830]/50 hover:-translate-y-1 transition-all bg-white dark:bg-[#1b1b1d]">
              <div class="flex items-start justify-between mb-5">
                <div class="w-11 h-11 bg-[#FBE830]/10 rounded-xl flex items-center justify-center">
                  <span class="material-symbols-outlined text-[#d4a800] dark:text-[#FBE830]">{icon}</span>
                </div>
                {count && (
                  <span class="text-[10px] font-bold px-2.5 py-1 rounded-full bg-[#FBE830]/15 text-[#d4a800] dark:text-[#FBE830] uppercase tracking-wider">{count}개 아이디어</span>
                )}
              </div>
              <h3 class="font-headline text-xl font-bold text-black dark:text-white mb-2 group-hover:text-[#d4a800] dark:group-hover:text-[#FBE830] transition-colors">{title}</h3>
              {preview && (
                <p class="text-sm text-slate-500 dark:text-gray-400 leading-relaxed mb-5">{preview}</p>
              )}
              {highlights.length > 0 && (
                <ul class="space-y-2 mb-6">
                  {highlights.slice(0, 3).map((h) => (
                    <li class="flex items-start gap-2 text-sm text-slate-700 dark:text-gray-300">
                      <span class="text-[#d4a800] dark:text-[#FBE830] mt-0.5 flex-shrink-0">•</span>
                      <span class="leading-snug">{h}</span>
                    </li>
                  ))}
                </ul>
              )}
              <div class="pt-4 border-t border-slate-100 dark:border-[#353437] text-xs font-bold text-[#d4a800] dark:text-[#FBE830] uppercase tracking-widest group-hover:translate-x-1 transition-transform inline-block">전체 보기 →</div>
            </a>
          );
        })}
      </div>
    </section>
  </section>
  </section>
</Layout>
