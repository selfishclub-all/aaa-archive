---
import Article from '../../layouts/Article.astro';
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const proposals = await getCollection('proposals');
  return proposals.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const title = entry.id.replace(/_/g, ' ');
const isSkillProposal = entry.id.includes('스킬');
const isBotInsight = entry.id.includes('봇') || entry.id.includes('인사이트');

const botInsights = [
  { category: '프로젝트 아이디어', icon: 'rocket_launch', items: [
    { title: '셀피쉬클럽 통합 콘텐츠 봇', date: '2026-04-01', desc: '에밀리의 CRM 자동화 + 오웬의 카드뉴스 생성 + 다니의 멀티채널 콘텐츠를 하나로 합친 통합 봇. "공유회 CRM 시작해줘 {URL}" 한 마디로 전부 생성.', highlight: '3명의 검증된 결과물을 합치면 전체 마케팅 자동화 가능' },
    { title: '멤버별 AI 어시스턴트 프레임워크', date: '2026-04-01', desc: '흐민의 Sullivan처럼 각 멤버가 자기만의 AI 어시스턴트를 만드는 프레임워크. CLAUDE.md + tone-guide + 에이전트 설계를 템플릿으로 제공.', highlight: '비개발자도 자기 업무에 맞는 봇을 만들 수 있음' },
  ]},
  { category: '이렇게 하면 더 좋겠다', icon: 'lightbulb', items: [
    { title: '과제 결과물 → 재사용 스킬로 변환', date: '2026-04-01', desc: '과제에서 만든 것 중 재사용 가능한 것을 .claude/commands/에 스킬로 등록. 다른 멤버도 /cardnews나 /multiuse로 바로 사용.', highlight: '이미 실전 검증된 것을 팀 전체 생산성으로' },
    { title: '에이전트 팀 설계 패턴 공유', date: '2026-04-01', desc: '에밀리의 6개 에이전트 팀 구조를 레퍼런스 패턴으로 문서화. 역할 분배 패턴을 공유하면 다음 과제에서 바로 활용 가능.', highlight: 'director/collector/planner/writer/media/dispatcher' },
  ]},
  { category: '자유 생각', icon: 'edit_note', items: [
    { title: '자동화의 단위는 채널이 아니라 워크플로우', date: '2026-04-01', desc: 'Week 02에서 5명 중 성공적인 결과물의 공통점은 채널 하나가 아니라 URL→분석→생성→배포 전체를 자동화한 것.', highlight: '워크플로우를 자동화하면 채널 추가가 쉬워진다' },
    { title: '비개발자도 Claude Code로 실전 프로젝트 완성', date: '2026-04-01', desc: '잽은 HTML/CSS/JS만으로 프리미엄 웹 제안서를 하루 만에 완성. CLAUDE.md를 잘 작성하면 코딩 경험이 적어도 복잡한 프로젝트 진행 가능.', highlight: 'AI 페어 프로그래밍의 좋은 사례' },
  ]},
];

const skills = [
  { name: '/multiuse', title: '원소스 멀티유즈 스킬', type: 'Claude Code 스킬', difficulty: '중급', icon: 'sync_alt', members: '에밀리, 다니, 띵끄', desc: 'URL 하나를 입력하면 인스타 캐러셀 + 스레드 + 링크드인 포스트를 한 번에 생성' },
  { name: '/cardnews', title: '인스타 카드뉴스 생성', type: 'Claude Code 스킬', difficulty: '중급', icon: 'photo_library', members: '오웬, 다니', desc: '주제를 입력하면 5장 카드뉴스 HTML 생성 + Playwright로 PNG 변환' },
  { name: '/crm', title: 'CRM 알림톡 자동 생성', type: 'Claude Code 스킬', difficulty: '고급', icon: 'campaign', members: '에밀리, 비비안', desc: '공유회 URL 입력하면 알림톡 9종 + 카플친 배너 + 오픈채팅 카피 자동 생성' },
  { name: '/bootstrap', title: 'CLAUDE.md 자동생성', type: 'Claude Code 스킬', difficulty: '초급', icon: 'description', members: '비비안, 에밀리, 잽', desc: '프로젝트 URL이나 설명을 입력하면 CLAUDE.md 프로젝트 맥락 파일 자동 생성' },
  { name: '/proposal', title: '웹 제안서 원클릭 생성', type: 'Claude Code 스킬', difficulty: '중급', icon: 'web', members: '잽, 띵끄', desc: '프로젝트 정보 입력하면 프리미엄 원페이지 웹 제안서 HTML 생성 + GitHub Pages 배포' },
  { name: 'Plugin', title: 'Obsidian 호기심 트래커', type: 'Obsidian 플러그인', difficulty: '고급', icon: 'psychology', members: '흐민, 다다', desc: '메모를 입력하면 AI가 답 대신 관련 질문을 던져서 생각을 확장하는 플러그인' },
];

const diffColor: Record<string, string> = {
  '초급': 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400',
  '중급': 'bg-[#FBE830]/15 text-[#d4a800] dark:text-[#FBE830]',
  '고급': 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400',
};
---

{isSkillProposal ? (
<Layout title="스킬 제안 - AAA 아카이브">
  <section class="pt-24 md:pt-32 pb-16 md:pb-24 px-6 md:px-12 max-w-7xl mx-auto">
    <div class="mb-16">
      <span class="text-[#d4a800] dark:text-[#FBE830] text-[10px] font-bold tracking-widest uppercase mb-4 block">Skill Proposals</span>
      <h1 class="text-4xl md:text-5xl font-headline font-extrabold tracking-tighter text-black dark:text-white mb-4">만들어볼 수 있는 스킬</h1>
      <p class="text-slate-500 dark:text-gray-400 text-lg max-w-2xl">학습 내용을 바탕으로 AI가 제안한 Claude Code 스킬, Obsidian 플러그인 아이디어</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {skills.map((skill) => (
        <div class="p-6 bg-slate-50 dark:bg-[#1b1b1d] border border-slate-100 dark:border-[#353437] rounded-xl hover:border-[#FBE830]/40 hover:shadow-lg transition-all group">
          <div class="flex items-start justify-between mb-4">
            <div class="w-10 h-10 bg-white dark:bg-[#2a2a2c] rounded-lg flex items-center justify-center shadow-sm">
              <span class="material-symbols-outlined text-[#d4a800] dark:text-[#FBE830]" style="font-variation-settings: 'FILL' 1;">{skill.icon}</span>
            </div>
            <span class={`text-[10px] font-bold px-2 py-1 rounded ${diffColor[skill.difficulty] || ''}`}>{skill.difficulty}</span>
          </div>
          <div class="font-mono text-xs text-[#d4a800] dark:text-[#FBE830] font-bold mb-2">{skill.name}</div>
          <h3 class="font-headline text-lg font-bold text-black dark:text-white mb-2">{skill.title}</h3>
          <p class="text-sm text-slate-500 dark:text-gray-400 leading-relaxed mb-4">{skill.desc}</p>
          <div class="pt-4 border-t border-slate-100 dark:border-[#353437] flex items-center justify-between">
            <span class="text-[10px] text-slate-400 dark:text-gray-500 font-medium">{skill.type}</span>
            <span class="text-[10px] text-slate-400 dark:text-gray-500">추천: {skill.members}</span>
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>
) : isBotInsight ? (
<Layout title="AAA 봇 인사이트 - AAA 아카이브">
  <section class="pt-24 md:pt-32 pb-16 md:pb-24 px-6 md:px-12 max-w-4xl mx-auto">
    <!-- Header -->
    <div class="mb-16 border-b border-slate-100 dark:border-[#353437] pb-12">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-8 h-8 bg-[#131315] dark:bg-[#FBE830] rounded-full flex items-center justify-center">
          <span class="material-symbols-outlined text-[#FBE830] dark:text-black text-sm">smart_toy</span>
        </div>
        <span class="text-[10px] font-bold tracking-widest text-[#d4a800] dark:text-[#FBE830] uppercase">AAA Bot · Newsletter</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-headline font-extrabold tracking-tighter text-black dark:text-white mb-4">
        이번 주 AAA Bot이<br/>발견한 것들
      </h1>
      <p class="text-slate-500 dark:text-gray-400 text-lg">멤버들의 과제와 인사이트에서 AI가 도출한 아이디어, 개선점, 생각들</p>
    </div>

    <!-- Feed -->
    {botInsights.map((section) => (
      <div class="mb-16">
        <div class="flex items-center gap-3 mb-8">
          <span class="material-symbols-outlined text-[#d4a800] dark:text-[#FBE830]">{section.icon}</span>
          <h2 class="text-xs font-bold uppercase tracking-widest text-black dark:text-white border-l-4 border-[#FBE830] pl-3">{section.category}</h2>
        </div>
        <div class="space-y-6">
          {section.items.map((item) => (
            <article class="p-6 md:p-8 border border-slate-100 dark:border-[#353437] rounded-xl hover:border-[#FBE830]/30 transition-all">
              <div class="flex items-center gap-3 mb-4">
                <span class="text-[10px] text-slate-400 dark:text-gray-500 font-medium">{item.date}</span>
              </div>
              <h3 class="font-headline text-xl font-bold text-black dark:text-white mb-3">{item.title}</h3>
              <p class="text-sm text-slate-600 dark:text-gray-400 leading-relaxed mb-4">{item.desc}</p>
              <div class="flex items-start gap-2 p-3 bg-[#FBE830]/5 dark:bg-[#FBE830]/10 rounded-lg">
                <span class="material-symbols-outlined text-[#d4a800] dark:text-[#FBE830] text-base mt-0.5">auto_awesome</span>
                <p class="text-xs font-medium text-[#d4a800] dark:text-[#FBE830]">{item.highlight}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    ))}

    <!-- Footer -->
    <div class="pt-8 border-t border-slate-100 dark:border-[#353437] flex items-center gap-4">
      <div class="w-10 h-10 bg-[#131315] dark:bg-[#2a2a2c] rounded-full flex items-center justify-center">
        <span class="material-symbols-outlined text-[#FBE830] text-sm">smart_toy</span>
      </div>
      <div>
        <p class="text-sm font-bold text-black dark:text-white">AAA Bot</p>
        <p class="text-[10px] text-slate-400 dark:text-gray-500 uppercase tracking-widest">Generated from Week 02 analysis data</p>
      </div>
    </div>
  </section>
</Layout>
) : (
<Article title={title} category="Proposal">
  <Content />
</Article>
)}
