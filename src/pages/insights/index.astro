---
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
import { getCollection } from 'astro:content';
const insights = await getCollection('insights');
const base = import.meta.env.BASE_URL;

// 모든 키워드 수집
const allKeywords = [...new Set(insights.flatMap(i => i.data.keywords || []))];
---
<Layout title="인사이트 - AAA 아카이브">
  <!-- Hero Banner -->
  <section class="pt-20 md:pt-24" style="background: linear-gradient(135deg, rgba(251,232,48,0.08) 0%, rgba(251,232,48,0.15) 40%, rgba(200,240,200,0.1) 100%);">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-12 py-10 md:py-14">
      <h1 class="font-headline text-2xl md:text-3xl font-extrabold tracking-tight text-black dark:text-white mb-2">인사이트</h1>
      <p class="text-sm md:text-base text-slate-600 dark:text-gray-400 mb-4">프로젝트를 만들면서 발견한 <strong class="text-black dark:text-white">생각과 아이디어</strong>를 기록합니다.</p>
      <div class="flex flex-wrap gap-2">
        <span class="px-3 py-1 text-xs font-medium border border-slate-200 dark:border-[#353437] rounded-full text-slate-600 dark:text-gray-400 bg-white/60 dark:bg-[#1b1b1d]/60">#인사이트</span>
        <span class="px-3 py-1 text-xs font-medium border border-slate-200 dark:border-[#353437] rounded-full text-slate-600 dark:text-gray-400 bg-white/60 dark:bg-[#1b1b1d]/60">#시행착오</span>
        <span class="px-3 py-1 text-xs font-medium border border-slate-200 dark:border-[#353437] rounded-full text-slate-600 dark:text-gray-400 bg-white/60 dark:bg-[#1b1b1d]/60">#배움</span>
      </div>
    </div>
  </section>

  <section class="pb-24 px-6 md:px-16 max-w-[1440px] mx-auto">
    <!-- Keyword Filter -->
    <div class="flex flex-wrap gap-2 mb-10">
      <button class="kw-filter active text-xs font-bold px-4 py-2 rounded-full transition-all" data-keyword="all">All</button>
      {allKeywords.map((kw) => (
        <button class="kw-filter text-xs font-bold px-4 py-2 rounded-full transition-all" data-keyword={kw}>{kw}</button>
      ))}
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8" id="insight-grid">
      {insights.map((insight) => (
        <a href={`${base}insights/${insight.id}/`} class="insight-item group bg-slate-50 dark:bg-[#1b1b1d] rounded-xl p-8 hover:shadow-lg transition-all duration-300 block border border-slate-100 dark:border-[#353437] hover:border-[#FBE830]/30" data-keywords={(insight.data.keywords || []).join(',')}>
          <div class="flex flex-wrap gap-2 mb-4">
            {insight.data.keywords?.map((kw: string) => (
              <span class="bg-[#FBE830]/15 text-[#d4a800] dark:text-[#FBE830] px-3 py-1.5 rounded-md text-[10px] font-bold uppercase tracking-wider border border-[#FBE830]/20">{kw}</span>
            ))}
            {(!insight.data.keywords || insight.data.keywords.length === 0) && (
              <span class="bg-[#FBE830]/15 text-[#d4a800] dark:text-[#FBE830] px-3 py-1.5 rounded-md text-[10px] font-bold uppercase tracking-wider border border-[#FBE830]/20">Insight</span>
            )}
          </div>
          <h3 class="font-headline text-xl font-semibold text-black dark:text-white mb-3 group-hover:text-[#d4a800] dark:group-hover:text-[#FBE830] transition-colors">{insight.id.replace(/-/g, ' ').replace(/_/g, ' ')}</h3>
          {insight.data.member && (
            <span class="text-slate-400 dark:text-gray-500 text-xs">by {insight.data.member}</span>
          )}
        </a>
      ))}
    </div>
  </section>

  <style>
    .kw-filter {
      background: transparent;
      color: #6b7280;
      border: 1px solid #e2e8f0;
    }
    .kw-filter:hover {
      border-color: #FBE830;
      color: #000;
    }
    .kw-filter.active {
      background: #FBE830;
      color: #000;
      border-color: #FBE830;
    }
    :global(.dark) .kw-filter {
      border-color: #353437;
      color: #9ca3af;
    }
    :global(.dark) .kw-filter:hover {
      border-color: #FBE830;
      color: #fff;
    }
    :global(.dark) .kw-filter.active {
      background: #FBE830;
      color: #000;
      border-color: #FBE830;
    }
    .insight-item.hidden-by-filter {
      display: none;
    }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const buttons = document.querySelectorAll('.kw-filter');
      const items = document.querySelectorAll('.insight-item');

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          buttons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');

          const keyword = btn.getAttribute('data-keyword');

          items.forEach(item => {
            const keywords = item.getAttribute('data-keywords') || '';
            if (keyword === 'all' || keywords.includes(keyword)) {
              item.classList.remove('hidden-by-filter');
            } else {
              item.classList.add('hidden-by-filter');
            }
          });
        });
      });
    });
  </script>
</Layout>
